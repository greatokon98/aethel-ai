{
  "version": "1.0",
  "vercel": {
    "adapter": "@astrojs/vercel",
    "adapterVersion": "^11.0.2",
    "buildCommand": "npm run build",
    "outputDir": "dist/",
    "framework": "Astro",
    "site": "https://aethel-blog.vercel.app",
    "envVarNames": []
  },
  "render": {
    "serviceType": "Web Service",
    "startCommand": "node src/index.js",
    "port": 3001,
    "nodeVersion": ">=18.0.0",
    "envVarNames": [
      "DATABASE_URL",
      "PORT",
      "GEMINI_API_KEY",
      "GROQ_API_KEY",
      "UNSPLASH_ACCESS_KEY",
      "PEXELS_API_KEY",
      "PIXABAY_API_KEY",
      "HF_API_KEY",
      "GITHUB_OWNER",
      "GITHUB_REPO"
    ],
    "domains": ["aethel-ai-e82y.onrender.com"],
    "healthEndpoint": "/api/health",
    "cronJobs": []
  },
  "githubActions": {
    "workflows": [
      {"name": "Auto Content Pipeline (Groq)", "schedule": "0 */3 * * *"},
      {"name": "Auto Content Pipeline", "schedule": "0 */6 * * *"},
      {"name": "Backup to Google Drive", "schedule": "0 */6 * * *"},
      {"name": "Test Build (Pull Request Check)", "trigger": "pull_request"}
    ]
  },
  "backup": {
    "scripts": [
      "scripts/upload-drive.mjs",
      "scripts/backup.mjs",
      "scripts/restore.mjs",
      "scripts/daemon.mjs"
    ],
    "requiredSecrets": [
      "GOOGLE_DRIVE_CLIENT_ID",
      "GOOGLE_DRIVE_CLIENT_SECRET",
      "GOOGLE_DRIVE_REFRESH_TOKEN",
      "DATABASE_URL",
      "BACKUP_DRIVE_FOLDER_ID",
      "BACKUP_ENCRYPT_KEY"
    ],
    "defaultInterval": "6h",
    "retentionPolicy": "14 daily, 4 weekly, 3 monthly"
  }
}
