      var navLinksHtml = (s.navigation.links || []).map(function(l, i) {
        return '<div class="settings-nav-row" data-idx="' + i + '">' +
          '<input type="text" class="settings-nav-label" value="' + escapeHtml(l.label) + '" placeholder="Label" />' +
          '<input type="text" class="settings-nav-url" value="' + escapeHtml(l.url) + '" placeholder="/page" />' +
          '<button class="settings-nav-remove" data-idx="' + i + '">×</button>' +
        '</div>';
      }).join('');

      return '<div class="settings-form">' +
        '<div class="post-list-header"><h1>Site Settings</h1></div>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">General</h2>' +
          '<div class="editor-field"><label>Site Title</label><input type="text" id="set-title" value="' + escapeHtml(s.site.title) + '" /></div>' +
          '<div class="editor-field"><label>Tagline</label><input type="text" id="set-tagline" value="' + escapeHtml(s.site.tagline) + '" /></div>' +
          '<div class="editor-field"><label>Description</label><textarea id="set-description" rows="2">' + escapeHtml(s.site.description) + '</textarea></div>' +
          '<div class="editor-field"><label>Copyright</label><input type="text" id="set-copyright" value="' + escapeHtml(s.site.copyright) + '" /></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Navigation</h2>' +
          '<div class="settings-nav-list" id="settings-nav-list">' + navLinksHtml + '</div>' +
          '<button class="admin-header__btn" id="btn-add-nav-link">+ Add Link</button>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Social Links</h2>' +
          '<div class="editor-field"><label>Twitter URL</label><input type="url" id="set-twitter" value="' + escapeHtml(s.social.twitter) + '" /></div>' +
          '<div class="editor-field"><label>GitHub URL</label><input type="url" id="set-github" value="' + escapeHtml(s.social.github) + '" /></div>' +
          '<div class="editor-field"><label>LinkedIn URL</label><input type="url" id="set-linkedin" value="' + escapeHtml(s.social.linkedin) + '" /></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Design</h2>' +
          '<div class="editor-field-row">' +
            '<div class="editor-field"><label>Accent Color</label><div class="settings-color-row"><input type="color" id="set-accent" value="' + s.design.accentColor + '" /><input type="text" id="set-accent-text" value="' + s.design.accentColor + '" /></div></div>' +
            '<div class="editor-field"><label>Accent Hover</label><div class="settings-color-row"><input type="color" id="set-accent-hover" value="' + s.design.accentHover + '" /><input type="text" id="set-accent-hover-text" value="' + s.design.accentHover + '" /></div></div>' +
          '</div>' +
          '<div class="editor-field"><label>Primary Color</label><div class="settings-color-row"><input type="color" id="set-primary" value="' + s.design.primaryColor + '" /><input type="text" id="set-primary-text" value="' + s.design.primaryColor + '" /></div></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Content</h2>' +
          '<div class="editor-field-row">' +
            '<div class="editor-field"><label>Hero Slides</label><input type="number" id="set-hero-count" value="' + s.content.heroCount + '" min="1" max="5" /></div>' +
            '<div class="editor-field"><label>Posts Per Page</label><input type="number" id="set-posts-per-page" value="' + s.content.postsPerPage + '" min="6" max="50" /></div>' +
          '</div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-search" ' + (s.content.sidebarWidgets.search ? 'checked' : '') + ' /> Search Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-trending" ' + (s.content.sidebarWidgets.trending ? 'checked' : '') + ' /> Trending Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-categories" ' + (s.content.sidebarWidgets.categories ? 'checked' : '') + ' /> Categories Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-popular" ' + (s.content.sidebarWidgets.popular ? 'checked' : '') + ' /> Popular Posts Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-newsletter" ' + (s.content.sidebarWidgets.newsletter ? 'checked' : '') + ' /> Newsletter Widget</label></div>' +
        '</section>' +

        '<div class="editor-actions">' +
          '<button class="btn-save" id="btn-save-settings">Save Settings</button>' +
