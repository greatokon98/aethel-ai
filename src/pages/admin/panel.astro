---
import AdminLayout from '../../components/admin/AdminLayout.astro';
---

<AdminLayout>
  <div id="app"></div>
<script is:inline>
window.AdminAPI = (function() {
  var CONFIG = {
    type: 'render',
    renderUrl: 'https://aethel-ai-e82y.onrender.com',
    owner: 'greatokon98',
    repo: 'aethel-ai',
    branch: 'main',
  };

  var GITHUB_PAT_KEY = 'aa_github_pat';
  var GITHUB_API = 'https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo;
  var BASE = CONFIG.type === 'render' ? CONFIG.renderUrl : '';

  function getPat() { return localStorage.getItem(GITHUB_PAT_KEY); }
  function storePat(token) { localStorage.setItem(GITHUB_PAT_KEY, token); }
  function removePat() { localStorage.removeItem(GITHUB_PAT_KEY); }
  function hasPat() { return !!getPat(); }

  function apiFetch(url, opts) {
    var pat = getPat();
    var o = opts || {};
    o.headers = o.headers || {};
    o.headers['Authorization'] = 'Bearer ' + pat;
    o.headers['Accept'] = 'application/vnd.github.v3+json';
    if (o.body && typeof o.body === 'object' && !(o.body instanceof FormData)) {
      o.body = JSON.stringify(o.body);
      o.headers['Content-Type'] = 'application/json';
    }
    return fetch(url, o).then(function(res) {
      if (!res.ok) {
        return res.json().then(function(e) {
          throw new Error(e.error || e.message || 'Request failed');
        }).catch(function(e) {
          if (e instanceof SyntaxError) throw new Error(res.statusText);
          throw e;
        });
      }
      return res.json();
    });
  }

  function generateId() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
  }

  // ---- GitHub file helpers (for posts/settings) ----
  function btoa(str) { return window.btoa(unescape(encodeURIComponent(str))); }
  function atob(str) {
    try { return decodeURIComponent(escape(window.atob(str))); } catch(e) { return window.atob(str); }
  }

  async function ghGetFile(path) {
    try {
      var data = await apiFetch(GITHUB_API + '/contents/' + path + '?ref=' + CONFIG.branch);
      return { content: atob(data.content), sha: data.sha };
    } catch(e) {
      if (e.message && e.message.indexOf('Not Found') !== -1) return null;
      throw e;
    }
  }

  async function ghSaveFile(path, content, sha) {
    var payload = { message: 'Update ' + path, content: btoa(content), branch: CONFIG.branch };
    if (sha) payload.sha = sha;
    var data = await apiFetch(GITHUB_API + '/contents/' + path, { method: 'PUT', body: payload });
    return data.content.sha;
  }

  async function ghDeleteFile(path, sha) {
    await apiFetch(GITHUB_API + '/contents/' + path, {
      method: 'DELETE',
      body: { message: 'Delete ' + path, sha: sha, branch: CONFIG.branch },
    });
  }

  // ---- Auth ----
  async function validatePat(token) {
    var pat = token || getPat();
    if (!pat) return false;
    try {
      if (CONFIG.type === 'render') {
        var data = await apiFetch(BASE + '/api/auth/validate');
        return data.valid;
      } else {
        var res = await fetch('https://api.github.com/user', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' },
        });
        if (!res.ok) return false;
        var repoRes = await fetch(GITHUB_API, {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' },
        });
        return repoRes.ok;
      }
    } catch(e) { return false; }
  }

  // ---- Posts (always GitHub) ----
  function parseFrontmatter(str) {
    var match = str.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
    if (!match) return { attrs: {}, body: str };
    var yaml = match[1];
    var body = (match[2] || '').trim();
    var attrs = {};
    var currentKey = null;
    var currentList = null;
    yaml.split('\n').forEach(function(line) {
      var listMatch = line.match(/^\s+-\s+(.*)$/);
      var kvMatch = line.match(/^(\w+):\s*(.*)$/);
      if (kvMatch) {
        if (currentKey && currentList !== null) { attrs[currentKey] = currentList; currentList = null; }
        currentKey = kvMatch[1];
        var val = kvMatch[2].replace(/^"(.*)"$/, '$1');
        if (val === 'true') attrs[currentKey] = true;
        else if (val === 'false') attrs[currentKey] = false;
        else if (val === '') { currentList = []; attrs[currentKey] = []; }
        else attrs[currentKey] = val;
      } else if (listMatch && currentKey) {
        if (currentList === null) currentList = [];
        currentList.push(listMatch[1].replace(/^"(.*)"$/, '$1'));
      }
    });
    if (currentKey && currentList !== null) attrs[currentKey] = currentList;
    return { attrs: attrs, body: body };
  }

  function buildFrontmatter(attrs, body) {
    var lines = ['---'];
    Object.keys(attrs).forEach(function(key) {
      if (key === '_sha') return;
      var val = attrs[key];
      if (Array.isArray(val)) {
        lines.push(key + ':');
        val.forEach(function(item) { lines.push('  - "' + item + '"'); });
      } else if (typeof val === 'boolean') {
        lines.push(key + ': ' + (val ? 'true' : 'false'));
      } else if (val !== undefined && val !== null) {
        lines.push(key + ': "' + String(val).replace(/"/g, '\\"') + '"');
      }
    });
    lines.push('---');
    if (body) lines.push('', body);
    return lines.join('\n');
  }

  async function listPosts(force) {
    if (!force) {
      try {
        var cached = sessionStorage.getItem('aa_posts_cache');
        if (cached) { var parsed = JSON.parse(cached); if (Array.isArray(parsed)) return parsed; }
      } catch(e) {}
    }
    try {
      var data = await apiFetch(GITHUB_API + '/contents/src/content/posts?ref=' + CONFIG.branch);
    } catch(e) {
      if (e.message && e.message.indexOf('Not Found') !== -1) return [];
      throw e;
    }
    var files = data.filter(function(f) { return f.name.endsWith('.md'); });
    var results = await Promise.all(files.map(async function(f) {
      try {
        var content = await apiFetch(GITHUB_API + '/contents/src/content/posts/' + f.name);
        var decoded = atob(content.content);
        var parsed = parseFrontmatter(decoded);
        var slug = f.name.replace(/\.md$/, '');
        return {
          slug: slug, name: f.name, sha: content.sha,
          title: parsed.attrs.title || slug, excerpt: parsed.attrs.excerpt || '',
          publishDate: parsed.attrs.publishDate || '',
          categories: parsed.attrs.categories || [], tags: parsed.attrs.tags || [],
          draft: parsed.attrs.draft || false, featured: parsed.attrs.featured || false, author: parsed.attrs.author || 'Aethel',
          featuredImage: parsed.attrs.featuredImage || '', body: parsed.body,
        };
      } catch(e) { return null; }
    }));
    var posts = results.filter(Boolean);
    posts.sort(function(a, b) { return new Date(b.publishDate) - new Date(a.publishDate); });
    try { sessionStorage.setItem('aa_posts_cache', JSON.stringify(posts)); } catch(e) {}
    return posts;
  }

  async function savePost(slug, attrs, body) {
    var content = buildFrontmatter(attrs, body);
    var path = 'src/content/posts/' + slug + '.md';
    var sha = attrs._sha || null;
    return ghSaveFile(path, content, sha);
  }

  async function deletePost(slug, sha) {
    return ghDeleteFile('src/content/posts/' + slug + '.md', sha);
  }

  // ---- Settings (always GitHub) ----
  var defaultSettings = {
    site: { title: 'Aethel_AI', tagline: 'Smart tools for everyday life — no jargon, just results.', description: 'A blog about AI, automation, and smart tools for everyday life.', copyright: 'All rights reserved.' },
    navigation: { links: [{ label: 'Home', url: '/' }, { label: 'Trending', url: '/trending', skipHeader: true }, { label: 'About', url: '/about' }, { label: 'Contact', url: '/contact' }] },
    social: { twitter: '#', github: '#', linkedin: '#' },
    design: { accentColor: '#3B82F6', accentHover: '#2563EB', primaryColor: '#0F1E36' },
    content: { heroCount: 3, postsPerPage: 12, sidebarWidgets: { search: true, trending: true, categories: true, popular: true, newsletter: true } },
    automation: { schedule: 'every 3 hours', lastRun: null, lastStatus: null },
  };

  async function loadSettings() {
    try {
      var file = await ghGetFile('src/config/site.json');
      if (!file) return JSON.parse(JSON.stringify(defaultSettings));
      var settings = JSON.parse(file.content);
      settings._sha = file.sha;
      return settings;
    } catch(e) {
      return JSON.parse(JSON.stringify(defaultSettings));
    }
  }

  async function saveSettings(settings) {
    var content = JSON.stringify(settings, null, 2);
    return ghSaveFile('src/config/site.json', content, settings._sha || null);
  }

  // ---- Messages ----
  async function loadMessages() {
    if (CONFIG.type === 'render') {
      var data = await apiFetch(BASE + '/api/messages');
      return { messages: data.messages || [] };
    } else {
      var file = await ghGetFile('data/messages.json');
      if (!file) return { messages: [], _sha: null };
      var data = JSON.parse(file.content);
      data._sha = file.sha;
      return data;
    }
  }

  async function saveMessages(data) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/messages', { method: 'POST', body: data });
    } else {
      var content = JSON.stringify({ messages: data.messages }, null, 2);
      return ghSaveFile('data/messages.json', content, data._sha || null);
    }
  }

  // ---- Search Queries ----
  async function loadSearchQueries() {
    if (CONFIG.type === 'render') {
      var data = await apiFetch(BASE + '/api/search-queries');
      return { queries: data.queries || [] };
    } else {
      try {
        var file = await ghGetFile('data/search-queries.json');
        if (!file) return { queries: [], _sha: null };
        var data = JSON.parse(file.content);
        data._sha = file.sha;
        return data;
      } catch(e) {
        return { queries: [], _sha: null };
      }
    }
  }

  async function saveSearchQueries(data) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/search-queries', { method: 'POST', body: data });
    } else {
      var content = JSON.stringify({ queries: data.queries }, null, 2);
      return ghSaveFile('data/search-queries.json', content, data._sha || null);
    }
  }

  // ---- Automation Runs ----
  async function loadAutomationRuns() {
    if (CONFIG.type === 'render') {
      var data = await apiFetch(BASE + '/api/automation-runs');
      return { runs: data.runs || [] };
    } else {
      try {
        var file = await ghGetFile('data/automation-runs.json');
        if (!file) return { runs: [], _sha: null };
        var data = JSON.parse(file.content);
        data._sha = file.sha;
        return data;
      } catch(e) {
        return { runs: [], _sha: null };
      }
    }
  }

  async function saveAutomationRuns(data) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/automation-runs', { method: 'POST', body: data });
    } else {
      var content = JSON.stringify({ runs: data.runs }, null, 2);
      return ghSaveFile('data/automation-runs.json', content, data._sha || null);
    }
  }

  async function triggerWorkflow() {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/automation-runs/trigger', { method: 'POST' });
    } else {
      var pat = getPat();
      var res = await fetch('https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo + '/actions/workflows/auto-content.yml/dispatches', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
        body: JSON.stringify({ ref: CONFIG.branch }),
      });
      if (!res.ok) {
        var errText;
        try { var errJson = await res.json(); errText = errJson.message; } catch(e) { errText = res.statusText; }
        throw new Error(errText || 'Failed to trigger workflow');
      }
      return true;
    }
  }

  async function getWorkflowStatus() {
    var pat = getPat();
    if (!pat) return null;
    try {
      var res = await fetch('https://api.github.com/repos/' + CONFIG.owner + '/' + CONFIG.repo + '/actions/workflows/auto-content.yml/runs?per_page=5', {
        headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' },
      });
      if (!res.ok) return null;
      var data = await res.json();
      return data.workflow_runs || [];
    } catch(e) { return null; }
  }

  // ---- Generate Post ----
  async function generatePost(title) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/generate', {
        method: 'POST',
        body: { title: title }
      });
    }
    throw new Error('Auto-generation requires Render backend');
  }

  // ---- Regenerate Post ----
  async function regeneratePost(title, body) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/generate/regenerate', {
        method: 'POST',
        body: { title: title, body: body }
      });
    }
    throw new Error('Regeneration requires Render backend');
  }

  async function generatePostGemini(title) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/generate/gemini', {
        method: 'POST',
        body: { title: title }
      });
    }
    throw new Error('Auto-generation requires Render backend');
  }

  async function regeneratePostGemini(title, body) {
    if (CONFIG.type === 'render') {
      return await apiFetch(BASE + '/api/generate/regenerate/gemini', {
        method: 'POST',
        body: { title: title, body: body }
      });
    }
    throw new Error('Regeneration requires Render backend');
  }

  // ---- Trending ----
  async function fetchTrending() {
    if (CONFIG.type === 'render') {
      try {
        var data = await apiFetch(BASE + '/api/trending');
        if (data && data.items && data.items.length) return data.items;
      } catch(e) {}
    }
    var feeds = [
      { url: 'https://techcrunch.com/category/artificial-intelligence/feed/', source: 'TechCrunch' },
      { url: 'https://www.theverge.com/ai-artificial-intelligence/rss/index.xml', source: 'The Verge' },
      { url: 'https://feeds.arstechnica.com/arstechnica/index', source: 'Ars Technica' },
    ];
    var allItems = [];
    var proxy = 'https://api.rss2json.com/v1/api.json?rss_url=';
    for (var i = 0; i < feeds.length; i++) {
      try {
        var res = await fetch(proxy + encodeURIComponent(feeds[i].url));
        if (!res.ok) continue;
        var data = await res.json();
        if (data.status !== 'ok' || !data.items) continue;
        data.items.forEach(function(item) {
          allItems.push({
            title: item.title || '',
            description: (item.description || '').replace(/<[^>]*>/g, '').slice(0, 200),
            pubDate: item.pubDate || item.pub_date || '',
            source: feeds[i].source, link: item.link || '',
          });
        });
      } catch(e) {}
    }
    allItems.sort(function(a, b) { return new Date(b.pubDate) - new Date(a.pubDate); });
    return allItems.slice(0, 30);
  }

  // ---- Popular ----
  async function fetchPopular() {
    if (CONFIG.type === 'render') {
      try {
        var data = await apiFetch(BASE + '/api/popular');
        if (data && data.items && data.items.length) return data.items;
      } catch(e) {}
    }
    var feeds = [
      { url: 'https://news.google.com/rss?hl=en-US&gl=US&ceid=US:en', source: 'Google News' },
      { url: 'https://rss.nytimes.com/services/xml/rss/nyt/Technology.xml', source: 'NYT Tech' },
      { url: 'https://feeds.feedburner.com/TechCrunch', source: 'TechCrunch' },
      { url: 'https://www.wired.com/feed/rss', source: 'Wired' },
    ];
    var allItems = [];
    var proxy = 'https://api.rss2json.com/v1/api.json?rss_url=';
    for (var i = 0; i < feeds.length; i++) {
      try {
        var res = await fetch(proxy + encodeURIComponent(feeds[i].url));
        if (!res.ok) continue;
        var data = await res.json();
        if (data.status !== 'ok' || !data.items) continue;
        data.items.forEach(function(item) {
          allItems.push({
            title: item.title || '',
            description: (item.description || '').replace(/<[^>]*>/g, '').slice(0, 200),
            pubDate: item.pubDate || item.pub_date || '',
            source: feeds[i].source, link: item.link || '',
          });
        });
      } catch(e) {}
    }
    allItems.sort(function(a, b) { return new Date(b.pubDate) - new Date(a.pubDate); });
    return allItems.slice(0, 30);
  }

  // ---- Public API ----
  function apiPost(path, body) {
    return apiFetch(BASE + path, { method: 'POST', body: body });
  }

  return {
    CONFIG: CONFIG,
    getPat: getPat, storePat: storePat, removePat: removePat, hasPat: hasPat,
    validatePat: validatePat,
    listPosts: listPosts, savePost: savePost, deletePost: deletePost,
    parseFrontmatter: parseFrontmatter, buildFrontmatter: buildFrontmatter,
    loadSettings: loadSettings, saveSettings: saveSettings, defaultSettings: defaultSettings,
    loadMessages: loadMessages, saveMessages: saveMessages, generateId: generateId,
    loadSearchQueries: loadSearchQueries, saveSearchQueries: saveSearchQueries,
    loadAutomationRuns: loadAutomationRuns, saveAutomationRuns: saveAutomationRuns,
    triggerWorkflow: triggerWorkflow, getWorkflowStatus: getWorkflowStatus,
    fetchTrending: fetchTrending,
    fetchPopular: fetchPopular,
    generatePost: generatePost, regeneratePost: regeneratePost,
    generatePostGemini: generatePostGemini, regeneratePostGemini: regeneratePostGemini,
    getFile: ghGetFile, saveFile: ghSaveFile,
    apiPost: apiPost,
  };
})();

(function() {
    // --- Theme ---
    try {
      var savedTheme = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.setAttribute('data-theme', savedTheme || (prefersDark ? 'dark' : 'light'));
    } catch(e) {}

    // --- Utilities ---
    function qs(s, ctx) { return (ctx || document).querySelector(s); }
    function qsa(s, ctx) { return Array.from((ctx || document).querySelectorAll(s)); }

    function escapeHtml(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }

    function formatDate(d) {
      if (!d) return '';
      return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function slugify(text) {
      return text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/[\s_]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 80);
    }

    function timeAgo(date) {
      var diff = Date.now() - new Date(date).getTime();
      var mins = Math.floor(diff / 60000);
      if (mins < 60) return mins + 'm ago';
      var hours = Math.floor(mins / 60);
      if (hours < 24) return hours + 'h ago';
      var days = Math.floor(hours / 24);
      return days + 'd ago';
    }

    function showToast(msg, type) {
      var t = document.getElementById('toast');
      if (!t) {
        t = document.createElement('div');
        t.id = 'toast';
        t.className = 'toast';
        document.body.appendChild(t);
      }
      t.textContent = msg;
      t.className = 'toast toast--' + type + ' toast--visible';
      clearTimeout(t._timer);
      t._timer = setTimeout(function() { t.classList.remove('toast--visible'); }, 3000);
    }

    // --- Cache ---
    var _cache = {};
    var CACHE_TTL = 30000;

    // --- State ---
    var state = {
      view: 'loading',
      posts: [],
      editingPost: null,
      postFilter: { search: '', status: 'all', category: 'all' },
      trendingItems: [],
      popularItems: [],
      settings: null,
      messages: null,
      searchData: null,
      automationRuns: null,
      workflowRuns: null,
      diag: null,
      error: null,
    };

    // --- Category Detection ---
    function detectCategory(title, desc) {
      var text = (title + ' ' + (desc || '')).toLowerCase();
      var rules = [
        { cat: 'Tech News', keywords: ['technology', 'gadget', 'update', 'release', 'launch', 'ios', 'android', 'windows', 'linux', 'cybersecurity', 'hack', 'breach', 'cloud', 'server', 'database', 'code', 'developer', 'digital', 'chip', 'processor', 'smartphone', 'app', 'software', 'silicon valley', 'big tech', 'meta', 'apple', 'google', 'microsoft', 'nvidia', 'intel', 'amd', 'crypto', 'startup', 'unicorn', 'nasdaq', 'tech industry', 'innovation'] },
        { cat: 'Business News', keywords: ['business', 'market', 'stock', 'economy', 'economic', 'trade', 'commerce', 'corporate', 'company', 'merger', 'acquisition', 'revenue', 'profit', 'earnings', 'financial', 'finance', 'banking', 'investment', 'fund', 'venture capital', 'ceo', 'executive', 'board', 'shareholder', 'sector', 'ipo', 'quarterly', 'fiscal', 'inflation', 'gdp'] },
        { cat: 'AI Tools', keywords: ['ai tool', 'assistant', 'chatbot', 'ai writing', 'prompt', 'copilot', 'choose', 'selection', 'ai assistant', 'ai bot', 'ai app', 'best ai'] },
        { cat: 'Content Creation', keywords: ['content', 'writing', 'blog', 'article', 'social media', 'video', 'podcast', 'seo', 'creator', 'newsletter', 'voice', 'storytelling', 'write', 'author'] },
        { cat: 'Productivity', keywords: ['productivity', 'efficiency', 'save time', 'time', 'habit', 'organize', 'focus', 'distraction', 'workflow tip', 'get more done'] },
        { cat: 'Workflow', keywords: ['workflow', 'process', 'pipeline', 'streamline', 'integration'] },
        { cat: 'Future of Work', keywords: ['future of work', 'remote', 'workplace', 'job', 'career', 'workforce', 'employment', 'regulation', 'safety', 'policy', 'compliance', 'restriction', 'ban', 'crowdsourcing', 'gig'] },
        { cat: 'Automation', keywords: ['automation', 'auto', 'trigger', 'workflow automation', 'bot', 'automated', 'mechanical turk'] },
        { cat: 'Creativity', keywords: ['creativity', 'creative', 'art', 'design', 'illustration', 'music', 'inspiration', 'imagination', 'entertainment'] },
        { cat: 'Entrepreneurship', keywords: ['entrepreneur', 'startup', 'fundraising', 'venture', 'founder', 'small business', 'investment'] },
        { cat: 'AI News', keywords: ['ai', 'artificial intelligence', 'machine learning', 'deep learning', 'chatgpt', 'openai', 'gemini', 'claude', 'llm', 'neural network', 'algorithm', 'intelligence'] },
      ];
      var scores = {};
      for (var i = 0; i < rules.length; i++) {
        var cat = rules[i].cat;
        var kw = rules[i].keywords;
        scores[cat] = 0;
        for (var k = 0; k < kw.length; k++) {
          if (text.indexOf(kw[k]) !== -1) scores[cat]++;
        }
      }
      var best = 'AI News';
      var bestScore = 0;
      for (var c in scores) {
        if (scores[c] > bestScore) { bestScore = scores[c]; best = c; }
      }
      return best;
    }

    var _trendingTimer = null;
    var _popularTimer = null;
    var _dashboardTimer = null;

    // --- View Renderers ---

    function renderLoading() {
      return '<div class="admin-loading"><div class="skeleton">' +
        '<div class="skeleton__bar skeleton__bar--short"></div>' +
        '<div class="skeleton__bar skeleton__bar--medium"></div>' +
        '<div class="skeleton__bar"></div>' +
        '<div class="skeleton__bar skeleton__bar--medium"></div>' +
        '<div class="skeleton__bar"></div>' +
      '</div></div>';
    }

    function renderError() {
      var msg = state.error || 'Something went wrong.';
      return '<div class="error-card">' +
        '<div class="error-card__icon">⚠️</div>' +
        '<h2 class="error-card__title">Connection Error</h2>' +
        '<p class="error-card__message">' + escapeHtml(msg) + '</p>' +
        '<div class="error-card__actions">' +
          '<button class="admin-header__btn admin-header__btn--primary" onclick="window.location.reload()">Try Again</button>' +
        '</div>' +
      '</div>';
    }

    function renderTabNav() {
      var tabs = [
        { id: 'dashboard', label: 'Dashboard' },
        { id: 'list', label: 'Posts' },
        { id: 'trending', label: 'Trending' },
        { id: 'popular', label: 'Popular' },
        { id: 'messages', label: 'Messages' },
        { id: 'search', label: 'Search' },
        { id: 'automation', label: 'Automation' },
        { id: 'settings', label: 'Settings' },
        { id: 'diagnostics', label: 'Diagnostics' },
      ];
      return '<nav class="admin-tabs">' + tabs.map(function(t) {
        return '<button class="admin-tab' + (state.view === t.id ? ' admin-tab--active' : '') + '" data-tab="' + t.id + '">' + t.label + '</button>';
      }).join('') + '</nav>';
    }

    // --- Dashboard ---
    function renderDashboard() {
      var postsCount = state.posts.length;
      var featuredCount = state.posts.filter(function(p) { return p.featured; }).length;
      var draftCount = state.posts.filter(function(p) { return p.draft; }).length;
      var popularCount = state.posts.filter(function(p) { return p.tags && p.tags.indexOf('popular') !== -1; }).length;
      var trendingCount = state.posts.filter(function(p) { return p.tags && p.tags.indexOf('trending') !== -1; }).length;
      var msgCount = state.messages ? state.messages.messages.length : 0;
      var unreadCount = state.messages ? state.messages.messages.filter(function(m) { return !m.read; }).length : 0;
      var searchCount = state.searchData ? state.searchData.queries.length : 0;
      var lastRun = state.automationRuns && state.automationRuns.runs.length > 0 ? state.automationRuns.runs[0] : null;

      var featuredSub = featuredCount + ' featured · ' + draftCount + ' draft · ' + trendingCount + ' trending · ' + popularCount + ' popular';

      return '<div>' +
        '<div class="post-list-header"><h1>Dashboard</h1></div>' +
        '<div class="dashboard-grid">' +
          statCard('Total Posts', postsCount, featuredSub, '📝') +
          clickableCard('Featured', featuredCount, '⭐', 'featured') +
          clickableCard('Draft', draftCount, '📄', 'draft') +
          clickableCard('Trending', trendingCount, '🔥', 'trending') +
          clickableCard('Popular', popularCount, '📈', 'popular') +
          statCard('Messages', msgCount, unreadCount + ' unread', '✉️') +
          statCard('Search Queries', searchCount, 'All time', '🔍') +
          statCard('Latest Post', state.posts.length > 0 ? formatDate(state.posts[0].publishDate) : '—', state.posts.length > 0 ? escapeHtml(state.posts[0].title) : 'No posts yet', '📄') +
        '</div>' +
        (lastRun ? '<section class="settings-section"><h2 class="settings-section-title">Last Automation Run</h2>' +
          '<div style="font-size:14px;line-height:1.6">' +
            '<p><strong>Status:</strong> <span class="run-status run-status--' + (lastRun.status || 'unknown') + '">' + (lastRun.status || 'Unknown') + '</span></p>' +
            '<p><strong>Triggered:</strong> ' + formatDate(lastRun.triggered_at) + ' (' + timeAgo(lastRun.triggered_at) + ')</p>' +
            (lastRun.posts_created ? '<p><strong>Posts created:</strong> ' + lastRun.posts_created + '</p>' : '') +
          '</div></section>' : '') +
      '</div>';
    }

    function statCard(label, value, sub, icon) {
      return '<div class="stat-card">' +
        '<div class="stat-card__label">' + icon + ' ' + label + '</div>' +
        '<div class="stat-card__value">' + value + '</div>' +
        (sub ? '<div class="stat-card__sub">' + sub + '</div>' : '') +
      '</div>';
    }

    function clickableCard(label, value, icon, filterType) {
      return '<div class="stat-card stat-card--clickable" data-filter="' + filterType + '">' +
        '<div class="stat-card__label">' + icon + ' ' + label + '</div>' +
        '<div class="stat-card__value">' + value + '</div>' +
        (value > 0 ? '<div class="stat-card__sub">View all →</div>' : '<div class="stat-card__sub">None</div>') +
      '</div>';
    }

    // --- Post List ---
    function renderPostList(posts) {
      var f = state.postFilter;
      var filtered = posts.filter(function(p) {
        if (f.status === 'draft' && !p.draft) return false;
        if (f.status === 'live' && p.draft) return false;
        if (f.category !== 'all' && (!p.categories || p.categories.indexOf(f.category) === -1)) return false;
        if (f.status === 'recent' && (!p.publishDate || new Date(p.publishDate) < new Date(Date.now() - 7 * 86400000))) return false;
        if (f.status === 'new' && (!p.publishDate || new Date(p.publishDate) < new Date(Date.now() - 3 * 86400000))) return false;
        if (f.status === 'newest' && (!p.publishDate || new Date(p.publishDate) < new Date(Date.now() - 86400000))) return false;
        if (f.search) {
          var q = f.search.toLowerCase();
          var title = (p.title || '').toLowerCase();
          if (title.indexOf(q) === -1) return false;
        }
        return true;
      });
      var total = posts.length;
      var shown = filtered.length;
      // Compute distinct categories from all posts
      var allCats = [];
      posts.forEach(function(p) { (p.categories || []).forEach(function(c) { if (allCats.indexOf(c) === -1) allCats.push(c); }); });
      allCats.sort();
      var catOpts = '<option value="all">All Categories</option>';
      allCats.forEach(function(c) {
        catOpts += '<option value="' + escapeHtml(c) + '"' + (f.category === c ? ' selected' : '') + '>' + escapeHtml(c) + '</option>';
      });
      var filterBar = '<div class="post-filter-bar">' +
        '<input type="text" class="post-filter-input" id="pf-search" placeholder="Search title..." value="' + escapeHtml(f.search) + '" />' +
        '<select class="post-filter-select" id="pf-status">' +
          '<option value="all"' + (f.status === 'all' ? ' selected' : '') + '>All Status</option>' +
          '<option value="live"' + (f.status === 'live' ? ' selected' : '') + '>Live</option>' +
          '<option value="draft"' + (f.status === 'draft' ? ' selected' : '') + '>Draft</option>' +
          '<option value="recent"' + (f.status === 'recent' ? ' selected' : '') + '>Recent (7 days)</option>' +
          '<option value="new"' + (f.status === 'new' ? ' selected' : '') + '>New (3 days)</option>' +
          '<option value="newest"' + (f.status === 'newest' ? ' selected' : '') + '>Newest (24h)</option>' +
        '</select>' +
        '<select class="post-filter-select" id="pf-category">' + catOpts + '</select>' +
      '</div>';

      if (posts.length === 0) {
        return '<div class="post-list-header">' +
          '<h1>Posts</h1>' +
          '<button class="admin-header__btn admin-header__btn--primary" id="btn-new-post">+ New Post</button>' +
        '</div>' +
        '<div class="empty-state">' +
          '<div class="empty-state__icon">✍️</div>' +
          '<h2>No posts yet</h2>' +
          '<p>Your first article is waiting to be written. Click "New Post" to get started.</p>' +
        '</div>';
      }
      var rows = filtered.map(function(p) {
        var date = p.publishDate ? formatDate(p.publishDate) : '';
        var cats = (p.categories || []).map(function(c) { return '<span class="post-cat">' + escapeHtml(c) + '</span>'; }).join('');
        var featuredBadge = p.featured ? '<span class="post-featured-badge">Featured</span>' : '';
        var draftBadge = p.draft ? '<span class="post-draft-badge">Draft</span>' : '<span class="post-live-badge">Live</span>';
        return '<tr>' +
          '<td data-label="Title"><div class="post-title">' + escapeHtml(p.title) + draftBadge + '</div></td>' +
          '<td data-label="Date" class="post-date">' + date + '</td>' +
          '<td data-label="Categories"><div class="post-cats">' + cats + '</div></td>' +
          '<td data-label="Status">' + featuredBadge + '</td>' +
          '<td data-label="Actions"><div class="post-actions">' +
            '<button class="btn-edit" data-slug="' + p.slug + '">Edit</button>' +
            '<button class="btn-delete" data-slug="' + p.slug + '" data-title="' + escapeHtml(p.title) + '">Delete</button>' +
          '</div></td>' +
        '</tr>';
      }).join('');
      return '<div class="post-list-header">' +
        '<h1>Posts <span class="count">(' + shown + '/' + total + ')</span></h1>' +
        '<button class="admin-header__btn admin-header__btn--primary" id="btn-new-post">+ New Post</button>' +
      '</div>' +
      filterBar +
      (shown === 0 ? '<div class="empty-state"><h2>No posts match filter</h2><p>Try changing your filter criteria.</p></div>' :
      '<table class="post-table">' +
        '<thead><tr><th>Title</th><th>Date</th><th>Categories</th><th></th><th></th></tr></thead>' +
        '<tbody>' + rows + '</tbody>' +
      '</table>');
    }

    // --- Editor ---
    function renderEditor(post) {
      var isNew = !post;
      var p = post || { title: '', excerpt: '', body: '', categories: [], tags: [], author: 'Aethel', featured: false, featuredImage: '', publishDate: new Date().toISOString().split('T')[0] };
      var cats = (p.categories || []).join(', ');
      var tags = (p.tags || []).join(', ');
      var previewContent = '';
      try { previewContent = marked.parse(p.body || ''); } catch(e) { previewContent = p.body || ''; }

      return '<div class="editor-form">' +
        '<h1>' + (isNew ? 'New Post' : 'Edit Post') + '</h1>' +
        '<div class="editor-field"><label>Title</label><input type="text" id="ed-title" value="' + escapeHtml(p.title) + '" /></div>' +
        '<div class="editor-field"><label>Slug</label><input type="text" id="ed-slug" value="' + (isNew ? '' : p.slug) + '"' + (isNew ? '' : ' readonly style="background:#F8FAFC;color:#94A3B8"') + ' /><div class="editor-hint">URL path (auto-generated from title if empty)</div></div>' +
        '<div class="editor-field"><label>Excerpt</label><textarea id="ed-excerpt" rows="3">' + escapeHtml(p.excerpt) + '</textarea></div>' +
        '<div class="editor-field-row">' +
          '<div class="editor-field"><label>Publish Date</label><input type="date" id="ed-date" value="' + (p.publishDate || '').split('T')[0] + '" /></div>' +
          '<div class="editor-field"><label>Author</label><input type="text" id="ed-author" value="' + escapeHtml(p.author || 'Aethel') + '" /></div>' +
        '</div>' +
        '<div class="editor-field-row">' +
          '<div class="editor-field"><label>Categories (comma-separated)</label><input type="text" id="ed-categories" value="' + escapeHtml(cats) + '" /></div>' +
          '<div class="editor-field"><label>Tags (comma-separated)</label><input type="text" id="ed-tags" value="' + escapeHtml(tags) + '" /></div>' +
        '</div>' +
        '<div class="editor-field"><label>Featured Image URL</label><div class="editor-image-row"><input type="url" id="ed-image" value="' + escapeHtml(p.featuredImage || '') + '" />' +
          '<button type="button" class="btn-search-images" id="btn-generate-image">Generate Image</button>' +
          '<button type="button" class="btn-search-images" id="btn-search-images">Search</button></div></div>' +
        '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="ed-featured" ' + (p.featured ? 'checked' : '') + ' /> Featured post</label></div>' +
        '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="ed-draft" ' + (p.draft ? 'checked' : '') + ' /> Save as draft (hidden from live site)</label></div>' +
        '<div class="editor-field"><label>Body (Markdown)</label><textarea class="editor-body" id="ed-body" oninput="window.updatePreview()">' + escapeHtml(p.body) + '</textarea></div>' +
        '<div class="editor-field"><label>Preview</label><div class="editor-preview" id="ed-preview">' + previewContent + '</div></div>' +
        '<div class="editor-actions">' +
          '<button class="btn-save" id="btn-save-post">' + (isNew ? 'Create Post' : 'Save Changes') + '</button>' +
          '<button class="btn-cancel" id="btn-cancel-edit">Cancel</button>' +
          (isNew ? '<button class="btn-regenerate" id="btn-generate">Generate with AI</button>' : '') +
          (!isNew ? '<button class="btn-regenerate" id="btn-regenerate">Regenerate with Groq</button>' : '') +
          (isNew ? '<button class="btn-regenerate btn-gemini" id="btn-generate-gemini">Generate with Gemini</button>' : '') +
          (!isNew ? '<button class="btn-regenerate btn-gemini" id="btn-regenerate-gemini">Regenerate with Gemini</button>' : '') +
          (!isNew ? '<button class="btn-delete" id="btn-editor-delete">Delete Post</button>' : '') +
          (!isNew ? '<button class="btn-regenerate btn-complete-ai" id="btn-complete-ai">Complete with AI</button>' : '') +
        '</div>' +
      '</div>' +
      '<div class="search-image-modal" id="image-modal-overlay" style="display:none">' +
        '<div class="modal-content-card">' +
          '<div class="modal-header-row">' +
            '<h2 class="modal-main-title">Search Image</h2>' +
            '<button class="modal-close-btn" id="closeModalCross">&times;</button>' +
          '</div>' +
          '<div class="search-bar-wrapper">' +
            '<input type="text" id="modalSearchInput" value="ai" placeholder="Type an image keyword..." class="modal-input-field" />' +
          '</div>' +
          '<div class="provider-tabs-row">' +
            '<button class="tab-selector-btn active" data-provider-id="unsplash">Unsplash</button>' +
            '<button class="tab-selector-btn" data-provider-id="pexels">Pexels</button>' +
            '<button class="tab-selector-btn" data-provider-id="pixabay">Pixabay</button>' +
          '</div>' +
          '<div class="results-display-area">' +
            '<div class="clean-uniform-grid" id="modalGridOutput">' +
              '<div class="fallback-status-msg">Type a keyword and press enter to search...</div>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    }

    // --- Trending ---
    function renderTrendingList() {
      var items = state.trendingItems;
      if (items.length === 0) {
        return '<div class="post-list-header">' +
          '<h1>Trending Now</h1>' +
          '<button class="admin-header__btn" id="btn-refresh-trending">Refresh</button>' +
        '</div>' +
        '<div class="admin-loading"><div class="admin-spinner"></div><p>Loading trending stories...</p></div>';
      }
      var rows = items.slice(0, 20).map(function(item, i) {
        var date = item.pubDate ? formatDate(item.pubDate) : '';
        var desc = (item.description || '').replace(/<[^>]*>/g, '').slice(0, 120);
        var slug = slugify(item.title);
        return '<div class="trending-card">' +
          '<div class="trending-card__num">' + String(i + 1).padStart(2, '0') + '</div>' +
          '<div class="trending-card__body">' +
            '<div class="trending-card__title">' + escapeHtml(item.title) + '</div>' +
            '<div class="trending-card__meta">' + escapeHtml(item.source) + ' · ' + date + '</div>' +
            (desc ? '<div class="trending-card__desc">' + escapeHtml(desc) + '…</div>' : '') +
          '</div>' +
          '<div class="trending-card__actions">' +
            '<button class="admin-header__btn admin-header__btn--outline trending-write" data-title="' + escapeHtml(item.title) + '" data-slug="' + slug + '" data-desc="' + escapeHtml(desc) + '">Write</button>' +
            '<button class="admin-header__btn admin-header__btn--primary trending-auto" data-title="' + escapeHtml(item.title) + '" data-slug="' + slug + '" data-desc="' + escapeHtml(desc) + '">Auto Write</button>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div class="post-list-header">' +
        '<h1>Trending Now <span class="count">(' + items.length + ')</span></h1>' +
        '<span class="trending-auto-badge">⟳ Auto 30s</span>' +
        '<button class="admin-header__btn" id="btn-refresh-trending">Refresh</button>' +
      '</div>' +
      '<div class="trending-list">' + rows + '</div>';
    }

    // --- Popular ---
    function renderPopularList() {
      var items = state.popularItems;
      if (items.length === 0) {
        return '<div class="post-list-header">' +
          '<h1>Popular Now</h1>' +
          '<button class="admin-header__btn" id="btn-refresh-popular">Refresh</button>' +
        '</div>' +
        '<div class="admin-loading"><div class="admin-spinner"></div><p>Loading popular stories...</p></div>';
      }
      var rows = items.slice(0, 20).map(function(item, i) {
        var date = item.pubDate ? formatDate(item.pubDate) : '';
        var desc = (item.description || '').replace(/<[^>]*>/g, '').slice(0, 120);
        var slug = slugify(item.title);
        return '<div class="trending-card">' +
          '<div class="trending-card__num">' + String(i + 1).padStart(2, '0') + '</div>' +
          '<div class="trending-card__body">' +
            '<div class="trending-card__title">' + escapeHtml(item.title) + '</div>' +
            '<div class="trending-card__meta">' + escapeHtml(item.source) + ' · ' + date + '</div>' +
            (desc ? '<div class="trending-card__desc">' + escapeHtml(desc) + '…</div>' : '') +
          '</div>' +
          '<div class="trending-card__actions">' +
            '<button class="admin-header__btn admin-header__btn--outline trending-write" data-title="' + escapeHtml(item.title) + '" data-slug="' + slug + '" data-source="popular" data-desc="' + escapeHtml(desc) + '">Write</button>' +
            '<button class="admin-header__btn admin-header__btn--primary trending-auto" data-title="' + escapeHtml(item.title) + '" data-slug="' + slug + '" data-source="popular" data-desc="' + escapeHtml(desc) + '">Auto Write</button>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div class="post-list-header">' +
        '<h1>Popular Now <span class="count">(' + items.length + ')</span></h1>' +
        '<span class="trending-auto-badge" style="color:#8B5CF6">⟳ Auto 30s</span>' +
        '<button class="admin-header__btn" id="btn-refresh-popular">Refresh</button>' +
      '</div>' +
      '<div class="trending-list">' + rows + '</div>';
    }

    // --- Messages ---
    function renderMessages() {
      var data = state.messages;
      if (!data) {
        return '<div class="admin-loading"><div class="admin-spinner"></div><p>Loading messages...</p></div>';
      }
      var msgs = data.messages || [];
      if (msgs.length === 0) {
        return '<div class="empty-state">' +
          '<div class="empty-state__icon">✉️</div>' +
          '<h2>No messages yet</h2>' +
          '<p>Messages from your contact form will appear here.</p>' +
        '</div>';
      }
      var list = msgs.map(function(m, i) {
        var preview = (m.body || '').slice(0, 100);
        return '<div class="message-card' + (m.read ? '' : ' message-card--unread') + '" data-idx="' + i + '">' +
          '<div class="message-card__header">' +
            '<span class="message-card__name">' + escapeHtml(m.name || 'Anonymous') + '</span>' +
            '<span class="message-card__date">' + formatDate(m.timestamp) + '</span>' +
          '</div>' +
          '<div class="message-card__subject">' + escapeHtml(m.subject || '(No subject)') + '</div>' +
          '<div class="message-card__preview">' + escapeHtml(preview) + '</div>' +
          '<div class="message-card__actions">' +
            '<button class="admin-header__btn" onclick="APP.toggleMessageRead(' + i + ')">' + (m.read ? 'Mark Unread' : 'Mark Read') + '</button>' +
            '<button class="admin-header__btn" onclick="APP.deleteMessage(' + i + ')">Delete</button>' +
            (m.email ? '<a href="mailto:' + m.email + '" class="admin-header__btn admin-header__btn--primary">Reply</a>' : '') +
          '</div>' +
        '</div>';
      }).join('');
      return '<div class="post-list-header">' +
        '<h1>Messages <span class="count">(' + msgs.length + ')</span></h1>' +
        (data._sha ? '<span style="font-size:13px;color:#94A3B8">' + msgs.filter(function(m) { return !m.read; }).length + ' unread</span>' : '') +
      '</div>' +
      '<div class="message-list">' + list + '</div>';
    }

    // --- Search Analytics ---
    function renderSearchAnalytics() {
      var data = state.searchData;
      if (!data) {
        return '<div class="admin-loading"><div class="admin-spinner"></div><p>Loading search data...</p></div>';
      }
      var queries = data.queries || [];
      if (queries.length === 0) {
        return '<div class="empty-state">' +
          '<div class="empty-state__icon">🔍</div>' +
          '<h2>No search data yet</h2>' +
          '<p>When visitors search on your site, queries will appear here.</p>' +
        '</div>';
      }
      // Top queries
      var freq = {};
      queries.forEach(function(q) {
        var key = q.query.toLowerCase().trim();
        freq[key] = freq[key] || { query: q.query, count: 0, last: q.timestamp };
        freq[key].count++;
        if (q.timestamp > freq[key].last) freq[key].last = q.timestamp;
      });
      var topQueries = Object.values(freq).sort(function(a, b) { return b.count - a.count; }).slice(0, 20);

      // Recent queries
      var recent = queries.slice().sort(function(a, b) { return new Date(b.timestamp) - new Date(a.timestamp); }).slice(0, 20);

      var topRows = topQueries.map(function(q) {
        return '<tr><td>' + escapeHtml(q.query) + '</td><td>' + q.count + '</td><td>' + timeAgo(q.last) + '</td></tr>';
      }).join('');
      var recentRows = recent.map(function(q) {
        return '<tr><td>' + escapeHtml(q.query) + '</td><td>' + timeAgo(q.timestamp) + '</td></tr>';
      }).join('');

      return '<div class="post-list-header">' +
        '<h1>Search Analytics</h1>' +
        '<span style="font-size:13px;color:#94A3B8">' + queries.length + ' total queries</span>' +
      '</div>' +
      '<div class="search-stats">' +
        '<div class="settings-section">' +
          '<h2 class="settings-section-title">Top Queries</h2>' +
          '<table class="search-table">' +
            '<thead><tr><th>Query</th><th>Count</th><th>Last</th></tr></thead>' +
            '<tbody>' + (topRows || '<tr><td colspan="3" style="text-align:center;color:#94A3B8;padding:20px">No data</td></tr>') + '</tbody>' +
          '</table>' +
        '</div>' +
        '<div class="settings-section">' +
          '<h2 class="settings-section-title">Recent Queries</h2>' +
          '<table class="search-table">' +
            '<thead><tr><th>Query</th><th>Time</th></tr></thead>' +
            '<tbody>' + (recentRows || '<tr><td colspan="2" style="text-align:center;color:#94A3B8;padding:20px">No data</td></tr>') + '</tbody>' +
          '</table>' +
        '</div>' +
      '</div>';
    }

    // --- Automation ---
    function renderAutomation() {
      var runs = state.automationRuns ? state.automationRuns.runs || [] : [];
      var wfRuns = state.workflowRuns || [];

      var runRows = runs.slice().reverse().map(function(run) {
        return '<div class="run-item">' +
          '<div>' +
            '<span class="run-status run-status--' + (run.status || 'unknown') + '">' + (run.status || 'Unknown') + '</span>' +
            ' <span style="color:#64748B">' + formatDate(run.triggered_at) + '</span>' +
          '</div>' +
          '<span style="color:#94A3B8;font-size:13px">' +
            (run.posts_created ? run.posts_created + ' posts' : '—') +
          '</span>' +
        '</div>';
      }).join('') || '<div style="text-align:center;padding:20px;color:#94A3B8">No runs yet</div>';

      var wfInfo = wfRuns.length > 0 ? wfRuns[0] : null;

      return '<div class="post-list-header">' +
        '<h1>Automation</h1>' +
        '<div class="automation-actions">' +
          '<button class="admin-header__btn admin-header__btn--primary" id="btn-run-automation">▶ Run Pipeline</button>' +
          '<button class="admin-header__btn" id="btn-refresh-automation">↻ Refresh</button>' +
        '</div>' +
      '</div>' +
      '<section class="settings-section">' +
        '<h2 class="settings-section-title">Pipeline Controls</h2>' +
        '<div style="font-size:14px;line-height:1.8">' +
          '<p><strong>Schedule:</strong> Every 3 hours (GitHub Actions)</p>' +
          (wfInfo ? '<p><strong>Last workflow run:</strong> <span class="run-status run-status--' + (wfInfo.conclusion || wfInfo.status) + '">' + (wfInfo.conclusion || wfInfo.status) + '</span> — ' + timeAgo(wfInfo.created_at) + '</p>' : '<p>No recent workflow runs</p>') +
          '<p style="color:#64748B;margin-top:8px">The auto-content pipeline fetches trending AI news, generates posts via Gemini, and commits them to the repo. Vercel auto-deploys on push.</p>' +
        '</div>' +
      '</section>' +
      '<section class="settings-section run-history">' +
        '<h2 class="settings-section-title">Run History</h2>' +
        runRows +
      '</section>';
    }

    // --- Settings ---
    function renderSettingsForm() {
      var s = state.settings || AdminAPI.defaultSettings;
      var navLinksHtml = (s.navigation.links || []).map(function(l, i) {
        return '<div class="settings-nav-row" data-idx="' + i + '">' +
          '<input type="text" class="settings-nav-label" value="' + escapeHtml(l.label) + '" placeholder="Label" />' +
          '<input type="text" class="settings-nav-url" value="' + escapeHtml(l.url) + '" placeholder="/page" />' +
          '<button class="settings-nav-remove" data-idx="' + i + '">×</button>' +
        '</div>';
      }).join('');

      return '<div class="settings-form">' +
        '<div class="post-list-header"><h1>Site Settings</h1></div>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">General</h2>' +
          '<div class="editor-field"><label>Site Title</label><input type="text" id="set-title" value="' + escapeHtml(s.site.title) + '" /></div>' +
          '<div class="editor-field"><label>Tagline</label><input type="text" id="set-tagline" value="' + escapeHtml(s.site.tagline) + '" /></div>' +
          '<div class="editor-field"><label>Description</label><textarea id="set-description" rows="2">' + escapeHtml(s.site.description) + '</textarea></div>' +
          '<div class="editor-field"><label>Copyright</label><input type="text" id="set-copyright" value="' + escapeHtml(s.site.copyright) + '" /></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Navigation</h2>' +
          '<div class="settings-nav-list" id="settings-nav-list">' + navLinksHtml + '</div>' +
          '<button class="admin-header__btn" id="btn-add-nav-link">+ Add Link</button>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Social Links</h2>' +
          '<div class="editor-field"><label>Twitter URL</label><input type="url" id="set-twitter" value="' + escapeHtml(s.social.twitter) + '" /></div>' +
          '<div class="editor-field"><label>GitHub URL</label><input type="url" id="set-github" value="' + escapeHtml(s.social.github) + '" /></div>' +
          '<div class="editor-field"><label>LinkedIn URL</label><input type="url" id="set-linkedin" value="' + escapeHtml(s.social.linkedin) + '" /></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Design</h2>' +
          '<div class="editor-field-row">' +
            '<div class="editor-field"><label>Accent Color</label><div class="settings-color-row"><input type="color" id="set-accent" value="' + s.design.accentColor + '" /><input type="text" id="set-accent-text" value="' + s.design.accentColor + '" /></div></div>' +
            '<div class="editor-field"><label>Accent Hover</label><div class="settings-color-row"><input type="color" id="set-accent-hover" value="' + s.design.accentHover + '" /><input type="text" id="set-accent-hover-text" value="' + s.design.accentHover + '" /></div></div>' +
          '</div>' +
          '<div class="editor-field"><label>Primary Color</label><div class="settings-color-row"><input type="color" id="set-primary" value="' + s.design.primaryColor + '" /><input type="text" id="set-primary-text" value="' + s.design.primaryColor + '" /></div></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">Content</h2>' +
          '<div class="editor-field-row">' +
            '<div class="editor-field"><label>Hero Slides</label><input type="number" id="set-hero-count" value="' + s.content.heroCount + '" min="1" max="5" /></div>' +
            '<div class="editor-field"><label>Posts Per Page</label><input type="number" id="set-posts-per-page" value="' + s.content.postsPerPage + '" min="6" max="50" /></div>' +
          '</div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-search" ' + (s.content.sidebarWidgets.search ? 'checked' : '') + ' /> Search Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-trending" ' + (s.content.sidebarWidgets.trending ? 'checked' : '') + ' /> Trending Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-categories" ' + (s.content.sidebarWidgets.categories ? 'checked' : '') + ' /> Categories Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-popular" ' + (s.content.sidebarWidgets.popular ? 'checked' : '') + ' /> Popular Posts Widget</label></div>' +
          '<div class="editor-field"><label class="editor-checkbox"><input type="checkbox" id="set-widget-newsletter" ' + (s.content.sidebarWidgets.newsletter ? 'checked' : '') + ' /> Newsletter Widget</label></div>' +
        '</section>' +

        '<section class="settings-section">' +
          '<h2 class="settings-section-title">GitHub Token</h2>' +
          '<div class="editor-field"><label>Personal Access Token</label><input type="password" id="set-pat" value="' + escapeHtml(AdminAPI.getPat() || '') + '" placeholder="ghp_..." /></div>' +
          '<div class="editor-field"><button class="btn-save" id="btn-save-pat">Save Token</button> <span id="pat-status" style="font-size:12px;color:#64748B"></span></div>' +
        '</section>' +

        '<div class="editor-actions">' +
          '<button class="btn-save" id="btn-save-settings">Save Settings</button>' +
        '</div>' +
      '</div>';
    }

    // --- Diagnostics ---
    function renderDiagnostics() {
      var d = state.diag || {};
      var badge = function(ok, text) { return '<span class="diag-badge diag-badge--' + (ok ? 'ok' : 'fail') + '">' + (text || (ok ? 'PASS' : 'FAIL')) + '</span>'; };
      var row = function(label, val, badgeHtml) { return '<div class="diag-row"><span class="diag-label">' + label + '</span>' + (badgeHtml ? badgeHtml : '<span class="diag-value">' + val + '</span>') + '</div>'; };

      return '<div class="diag">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">' +
          '<h2>Diagnostics</h2>' +
          '<button class="admin-header__btn admin-header__btn--primary" onclick="APP.runDiagnostics()">Run Again</button>' +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>GitHub Token</h3>' +
          (d.patDone ? (
            row('Token Status', d.patOk ? badge(true, 'Valid') : badge(false, 'Invalid or missing')) +
            (d.patPreview ? row('Token Preview', escapeHtml(d.patPreview + '...')) : '') +
            (d.patUser ? row('Authenticated as', escapeHtml(d.patUser)) : '')
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking token...</div>') +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>REPO ACCESS</h3>' +
          (d.repoDone ? (
            row('Repository', 'greatokon98/aethel-ai') +
            row('Status', d.repoOk ? badge(true, 'Accessible') : badge(false, 'Not accessible'))
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking repo access...</div>') +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>Posts Directory</h3>' +
          (d.postsDone ? (
            row('Files Found', String(d.postsCount)) +
            row('Status', d.postsOk ? badge(true, 'OK') : badge(false, d.postsError))
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking posts...</div>') +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>Data Files</h3>' +
          (d.dataDone ? (
            row('messages.json', d.messagesOk ? badge(true, 'Accessible') : badge(false, 'Not found or error')) +
            row('search-queries.json', d.searchOk ? badge(true, 'Accessible') : badge(false, 'Not found or error'))
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking data files...</div>') +
        '</div>' +

        '<div class="diag-section" style="background:#EFF6FF;border-color:#93C5FD">' +
          '<h3 style="color:#1D4ED8">Recommendation</h3>' +
          '<div style="font-size:14px;line-height:1.6">' +
            (d.recommendation || 'Run diagnostics to check the system status.') +
          '</div>' +
        '</div>' +
      '</div>';
    }

    // --- Main render ---
    function render() {
      var app = document.getElementById('app');
      if (!app) return;
      var html = '';

      // Header
      var userData;
      try { userData = JSON.parse(localStorage.getItem('aa_user')); } catch(e) {}
      var userName = (userData && userData.name) || 'Admin';
      html += '<header class="admin-header">' +
        '<a href="/" class="admin-header__brand">' +
          '<svg width="24" height="24" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="6" fill="#3B82F6"/><path d="M8 22 L11 7 Q11.3 5.5 13 5.5 Q14.7 5.5 15 7 L18 22 L16 22 L15 16.5 H10 L9 22 Z M10.5 14.5 H14.5 L12.5 9.5 Z" fill="white"/></svg>' +
          '<span class="admin-header__brand-text">Aethel_AI</span>' +
        '</a>' +
        '<div class="admin-header__actions">' +
          '<span class="admin-header__user" id="header-user">' + escapeHtml(userName) + '</span>' +
          '<button class="theme-toggle-btn" id="theme-toggle" title="Toggle theme">☀️</button>' +
          '<button class="admin-header__btn" onclick="window.location.href=\'/\'">View Site</button>' +
          '<button class="admin-header__btn" id="btn-logout">Sign Out</button>' +
        '</div>' +
      '</header>';

      // Tab navigation (skip for loading/error)
      if (state.view !== 'loading' && state.view !== 'error') {
        html += renderTabNav();
      }

      // Content
      html += '<div class="admin-container">';
      if (state.view === 'loading') {
        html += renderLoading();
      } else if (state.view === 'error') {
        html += renderError();
      } else if (state.view === 'dashboard') {
        html += renderDashboard();
      } else if (state.view === 'list') {
        html += renderPostList(state.posts);
      } else if (state.view === 'editor') {
        html += renderEditor(state.editingPost);
      } else if (state.view === 'trending') {
        html += renderTrendingList();
      } else if (state.view === 'popular') {
        html += renderPopularList();
      } else if (state.view === 'messages') {
        html += renderMessages();
      } else if (state.view === 'search') {
        html += renderSearchAnalytics();
      } else if (state.view === 'automation') {
        html += renderAutomation();
      } else if (state.view === 'settings') {
        html += renderSettingsForm();
      } else if (state.view === 'diagnostics') {
        html += renderDiagnostics();
      }
      html += '</div>';

      // Persist editor state before rendering
      if (state.view === 'editor') {
        try { sessionStorage.setItem('aa_editing_post', JSON.stringify(state.editingPost || null)); } catch(e) {}
      }

      app.innerHTML = html;
      bindEvents();
    }

    // --- Event Binding ---
    function bindEvents() {
      // Theme toggle
      try {
        var themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
          var currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
          themeBtn.textContent = currentTheme === 'dark' ? '🌙' : '☀️';
          themeBtn.addEventListener('click', function() {
            var newTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            themeBtn.textContent = newTheme === 'dark' ? '🌙' : '☀️';
          });
        }
      } catch(e) {}

      // Sign out
      var logoutBtn = document.getElementById('btn-logout');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          AdminAPI.removePat();
          window.location.href = '/admin/';
        });
      }

      // Stat card clicks
      qsa('.stat-card--clickable').forEach(function(card) {
        card.addEventListener('click', function() {
          var filter = this.dataset.filter;
          var labels = { featured: 'Featured', draft: 'Draft', trending: 'Trending', popular: 'Popular' };
          showFilteredPosts(filter, labels[filter] || filter);
        });
      });

      // Post filter bar
      var _filterTimer = null;
      function applyFilter() {
        var activeEl = document.activeElement;
        var activeId = activeEl ? activeEl.id : null;
        var selStart, selEnd;
        if (activeEl && activeEl.tagName === 'INPUT') {
          selStart = activeEl.selectionStart;
          selEnd = activeEl.selectionEnd;
        }
        clearTimeout(_filterTimer);
        _filterTimer = setTimeout(function() {
          var searchEl = document.getElementById('pf-search');
          var statusEl = document.getElementById('pf-status');
          var catEl = document.getElementById('pf-category');
          if (searchEl) state.postFilter.search = searchEl.value;
          if (statusEl) state.postFilter.status = statusEl.value;
          if (catEl) state.postFilter.category = catEl.value;
          state.view = 'list';
          render();
          if (activeId) {
            var newEl = document.getElementById(activeId);
            if (newEl) {
              newEl.focus();
              if (selStart !== undefined) newEl.setSelectionRange(selStart, selEnd);
            }
          }
        }, 300);
      }
      var pfSearch = document.getElementById('pf-search');
      var pfStatus = document.getElementById('pf-status');
      var pfCat = document.getElementById('pf-category');
      if (pfSearch) pfSearch.addEventListener('input', applyFilter);
      if (pfStatus) pfStatus.addEventListener('change', applyFilter);
      if (pfCat) pfCat.addEventListener('change', applyFilter);

      // New post
      var newBtn = document.getElementById('btn-new-post');
      if (newBtn) {
        newBtn.addEventListener('click', function() {
          state.view = 'editor';
          state.editingPost = null;
          render();
        });
      }

      // Edit buttons
      qsa('.btn-edit').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = this.dataset.slug;
          var post = state.posts.find(function(p) { return p.slug === slug; });
          if (post) {
            state.editingPost = JSON.parse(JSON.stringify(post));
            state.view = 'editor';
            render();
          }
        });
      });

      // Delete buttons
      qsa('.btn-delete').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = this.dataset.slug;
          var title = this.dataset.title;
          if (confirm('Delete "' + title + '"? This cannot be undone.')) {
            var post = state.posts.find(function(p) { return p.slug === slug; });
            if (post) handleDelete(post);
          }
        });
      });

      // Cancel edit
      var cancelBtn = document.getElementById('btn-cancel-edit');
      if (cancelBtn) {
        cancelBtn.addEventListener('click', function() { state.view = 'list'; render(); });
      }

      // Save post
      var saveBtn = document.getElementById('btn-save-post');
      if (saveBtn) {
        saveBtn.addEventListener('click', handleSave);
      }

      // Editor delete
      var delBtn = document.getElementById('btn-editor-delete');
      if (delBtn) {
        delBtn.addEventListener('click', function() {
          if (state.editingPost && confirm('Delete "' + state.editingPost.title + '"? This cannot be undone.')) {
            handleDelete(state.editingPost);
          }
        });
      }

      // Generate with AI
      var genBtn = document.getElementById('btn-generate');
      if (genBtn) {
        genBtn.addEventListener('click', handleGenerate);
      }

      // Regenerate with Groq
      var regenBtn = document.getElementById('btn-regenerate');
      if (regenBtn) {
        regenBtn.addEventListener('click', handleRegenerate);
      }

      // Generate Image button
      var genImgBtn = document.getElementById('btn-generate-image');
      if (genImgBtn) {
        genImgBtn.addEventListener('click', handleGenerateImage);
      }

      // Image URL normalize on blur
      var edImage = document.getElementById('ed-image');
      if (edImage) {
        edImage.addEventListener('blur', function() {
          var val = this.value.trim();
          if (!val) return;
          if (val.match(/(unsplash\.com\/photos|pexels\.com\/photo)/)) {
            AdminAPI.apiPost('/api/generate/images/normalize', { url: val })
              .then(function(d) { if (d.normalizedUrl) edImage.value = d.normalizedUrl; })
              .catch(function() {});
          }
        });
      }

      // Generate with Gemini
      var genGeminiBtn = document.getElementById('btn-generate-gemini');
      if (genGeminiBtn) {
        genGeminiBtn.addEventListener('click', handleGenerateGemini);
      }

      // Regenerate with Gemini
      var regenGeminiBtn = document.getElementById('btn-regenerate-gemini');
      if (regenGeminiBtn) {
        regenGeminiBtn.addEventListener('click', handleRegenerateGemini);
      }

      // Complete with AI
      var completeAiBtn = document.getElementById('btn-complete-ai');
      if (completeAiBtn) {
        completeAiBtn.addEventListener('click', handleCompleteAI);
      }

      // Image search modal
      setupAstroImageModal();
      document.addEventListener('astro:page-load', setupAstroImageModal);

      // Tab navigation
      qsa('.admin-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
          var view = this.dataset.tab;
          switchView(view);
        });
      });

      // Trending write buttons
      qsa('.trending-write').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var title = this.dataset.title;
          var slug = this.dataset.slug;
          var source = this.dataset.source || 'trending';
          var cat = detectCategory(title, this.dataset.desc || '');
          state.editingPost = {
            title: title,
            slug: slug,
            excerpt: '',
            body: '<!-- Write this post in the Aethel_AI voice:\n- First-person, honest, practical\n- Short punchy paragraphs (2-3 sentences)\n- Bold for **emphasis** on key concepts\n- No jargon \u2014 explain everything\n- Address the reader directly ("you")\n- Share real results, practical takeaways\n- End with a one-sentence takeaway\n-->\n\n## Key Points\n\n- \n- \n- \n\n## The Story\n\n\n\n## Why It Matters\n\n',
            categories: [cat],
            tags: [source],
            author: 'Aethel',
            featured: false,
            featuredImage: '',
            publishDate: new Date().toISOString().split('T')[0],
            sha: null,
          };
          state.view = 'editor';
          render();
          // Auto-generate featured image from title
          try {
            var data = await AdminAPI.apiPost('/api/generate/images/generate', { title: title, category: cat });
            if (data.url) {
              var imgEl = document.getElementById('ed-image');
              if (imgEl) imgEl.value = data.url;
            }
          } catch (e) {
            // Silent fail — user can manually search
          }
        });
      });

      // Trending auto-generate buttons
      qsa('.trending-auto').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var title = this.dataset.title;
          var slug = this.dataset.slug;
          var source = this.dataset.source || 'trending';
          var cat = detectCategory(title, this.dataset.desc || '');
          var btnEl = this;
          btnEl.disabled = true;
          btnEl.textContent = 'Generating...';
          try {
            var result = await AdminAPI.generatePost(title);
            var content = result.content;
            state.editingPost = {
              title: content.title || title,
              slug: slugify(content.title || title),
              excerpt: content.excerpt || '',
              body: content.body || '',
              categories: content.category ? [content.category] : [cat],
              tags: content.tags || [source],
              author: 'Aethel',
              featured: false,
              featuredImage: content.featuredImage || '',
              publishDate: new Date().toISOString().split('T')[0],
              sha: null,
            };
            state.view = 'editor';
            render();
            showToast('Content generated! Review and publish.', 'success');
          } catch(err) {
            showToast('Generation failed: ' + err.message, 'error');
            btnEl.disabled = false;
            btnEl.textContent = 'Auto Write';
          }
        });
      });

      // Trending edit buttons (popular posts)
      qsa('.trending-edit').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = this.dataset.slug;
          var post = state.posts.find(function(p) { return p.slug === slug; });
          if (post) {
            state.editingPost = JSON.parse(JSON.stringify(post));
            state.view = 'editor';
            render();
          }
        });
      });

      // Refresh trending
      var refreshBtn = document.getElementById('btn-refresh-trending');
      if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
          state.trendingItems = [];
          render();
          loadTrending();
        });
      }

      // Refresh popular
      var refreshPopularBtn = document.getElementById('btn-refresh-popular');
      if (refreshPopularBtn) {
        refreshPopularBtn.addEventListener('click', function() {
          state.popularItems = [];
          render();
          loadPopular();
        });
      }

      // Settings: add nav link
      var addNavBtn = document.getElementById('btn-add-nav-link');
      if (addNavBtn) {
        addNavBtn.addEventListener('click', function() {
          var list = document.getElementById('settings-nav-list');
          if (!list) return;
          var div = document.createElement('div');
          div.className = 'settings-nav-row';
          div.innerHTML = '<input type="text" class="settings-nav-label" value="" placeholder="Label" />' +
            '<input type="text" class="settings-nav-url" value="" placeholder="/page" />' +
            '<button class="settings-nav-remove">×</button>';
          list.appendChild(div);
          div.querySelector('.settings-nav-remove').addEventListener('click', function() { div.remove(); });
        });
      }

      // Settings: remove nav link
      qsa('.settings-nav-remove').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var row = this.closest('.settings-nav-row');
          if (row) row.remove();
        });
      });

      // Settings: color picker sync
      function syncColor(pickerId, textId) {
        var picker = document.getElementById(pickerId);
        var text = document.getElementById(textId);
        if (picker && text) {
          picker.addEventListener('input', function() { text.value = this.value; });
          text.addEventListener('input', function() { picker.value = this.value; });
        }
      }
      syncColor('set-accent', 'set-accent-text');
      syncColor('set-accent-hover', 'set-accent-hover-text');
      syncColor('set-primary', 'set-primary-text');

      // Settings: save
      var saveSettingsBtn = document.getElementById('btn-save-settings');
      if (saveSettingsBtn) {
        saveSettingsBtn.addEventListener('click', saveSettings);
      }

      // Settings: save PAT
      var savePatBtn = document.getElementById('btn-save-pat');
      if (savePatBtn) {
        savePatBtn.addEventListener('click', function() {
          var patInput = document.getElementById('set-pat');
          var statusEl = document.getElementById('pat-status');
          if (patInput && patInput.value.trim()) {
            AdminAPI.storePat(patInput.value.trim());
            statusEl.textContent = 'Token saved to browser.';
            statusEl.style.color = '#16A34A';
          } else {
            AdminAPI.removePat();
            statusEl.textContent = 'Token removed from browser.';
            statusEl.style.color = '#64748B';
          }
        });
      }

      // Automation: run pipeline
      var runBtn = document.getElementById('btn-run-automation');
      if (runBtn) {
        runBtn.addEventListener('click', function() {
          if (confirm('Trigger the auto-content pipeline now? This will generate new posts via Gemini.')) {
            var btn = this;
            btn.disabled = true;
            btn.textContent = 'Running...';
            AdminAPI.triggerWorkflow()
              .then(function() {
                showToast('Pipeline triggered! Check back in a few minutes.', 'success');
                btn.disabled = false;
                btn.textContent = '▶ Run Pipeline';
                // Log the run
                loadAutomationRuns();
              })
              .catch(function(err) {
                showToast('Error: ' + err.message, 'error');
                btn.disabled = false;
                btn.textContent = '▶ Run Pipeline';
              });
          }
        });
      }

      // Automation: refresh
      var refreshAutoBtn = document.getElementById('btn-refresh-automation');
      if (refreshAutoBtn) {
        refreshAutoBtn.addEventListener('click', function() {
          loadAutomationRuns();
        });
      }
    }

    // --- View switching ---
    function switchView(view) {
      if (view !== 'trending') {
        clearInterval(_trendingTimer);
        _trendingTimer = null;
      }
      if (view !== 'popular') {
        clearInterval(_popularTimer);
        _popularTimer = null;
      }
      if (view !== 'dashboard') {
        clearInterval(_dashboardTimer);
        _dashboardTimer = null;
      }
      state.view = view;
      try { sessionStorage.setItem('aa_active_tab', view); } catch(e) {}
      if (view === 'dashboard') {
        loadDashboard();
      } else if (view === 'trending') {
        loadTrending();
      } else if (view === 'popular') {
        loadPopular();
      } else if (view === 'settings') {
        loadSettings();
      } else if (view === 'messages') {
        loadMessages();
      } else if (view === 'search') {
        loadSearchData();
      } else if (view === 'automation') {
        loadAutomationRuns();
      } else {
        render();
      }
    }

    // --- Data Loading ---
    async function loadDashboard() {
      if (state.view !== 'dashboard') return;
      render();
      var results = await Promise.all([
        AdminAPI.listPosts(true).catch(function() { return state.posts || []; }),
        AdminAPI.loadMessages().catch(function() { return state.messages || { messages: [] }; }),
        AdminAPI.loadSearchQueries().catch(function() { return state.searchData || { queries: [] }; }),
        AdminAPI.loadAutomationRuns().catch(function() { return state.automationRuns || { runs: [] }; }),
      ]);
      if (state.view !== 'dashboard') return;
      state.posts = results[0];
      state.messages = results[1];
      state.searchData = results[2];
      state.automationRuns = results[3];
      _cache.dashboard = Date.now();
      render();
      clearInterval(_dashboardTimer);
      _dashboardTimer = setInterval(function() {
        loadDashboard();
      }, 30000);
    }

    async function loadPosts(force) {
      if (!force && _cache.posts && Date.now() - _cache.posts < CACHE_TTL && state.posts.length > 0) {
        state.view = 'list';
        render();
        return;
      }
      state.view = 'loading';
      render();
      try {
        state.posts = await AdminAPI.listPosts(force);
        _cache.posts = Date.now();
        state.view = 'list';
      } catch(e) {
        state.view = 'error';
        state.error = e.message;
      }
      render();
    }

    async function loadTrending() {
      if (state.view !== 'trending') return;
      clearInterval(_trendingTimer);
      _trendingTimer = null;
      state.trendingItems = [];
      render();
      try {
        state.trendingItems = await AdminAPI.fetchTrending();
      } catch(e) {
        state.trendingItems = [];
      }
      if (state.view !== 'trending') return;
      render();
      _trendingTimer = setInterval(async function() {
        if (state.view !== 'trending') return;
        try {
          state.trendingItems = await AdminAPI.fetchTrending();
          if (state.view !== 'trending') return;
          render();
        } catch(e) {}
      }, 30000);
    }

