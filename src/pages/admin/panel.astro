    // --- Image Search Modal ---
    function setupAstroImageModal() {
      var overlay = document.getElementById('image-modal-overlay');
      var searchInput = document.getElementById('modalSearchInput');
      var grid = document.getElementById('modalGridOutput');
      var tabButtons = document.querySelectorAll('[data-provider-id]');
      var closeBtn = document.getElementById('closeModalCross');
      if (!overlay || !searchInput || !grid || tabButtons.length === 0) return;

      var selectedProvider = 'unsplash';

      function closeModal() { overlay.style.display = 'none'; }
      if (closeBtn) closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', function(e) { if (e.target === overlay) closeModal(); });

      function executeImageFetch() {
        var queryStr = searchInput.value.trim();
        if (!queryStr) {
          grid.innerHTML = '<div class="fallback-status-msg">Please enter a search keyword.</div>';
          return;
        }
        grid.innerHTML = '<div class="fallback-status-msg">Searching ' + selectedProvider + '...</div>';
        var pat = getPat();
        fetch(BASE + '/api/generate/images/search', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + (pat || '')
          },
          body: JSON.stringify({ provider: selectedProvider, query: queryStr })
        })
        .then(function(res) {
          if (!res.ok) {
            return res.json().then(function(err) {
              throw new Error(err.error || 'Request failed with status ' + res.status);
            });
          }
          return res.json();
        })
        .then(function(imageCollection) {
          if (!Array.isArray(imageCollection) || imageCollection.length === 0) {
            grid.innerHTML = '<div class="fallback-status-msg">No results found for "' + queryStr + '" on ' + selectedProvider + '.</div>';
            return;
          }
          grid.innerHTML = imageCollection.map(function(img) {
            var prov = img.provider || selectedProvider;
            return '<div class="image-asset-card" data-url="' + img.src + '">' +
              '<span class="provider-badge badge-' + prov + '">' + prov + '</span>' +
              '<img class="card-img-element" src="' + img.src + '" alt="Media asset" loading="lazy" />' +
            '</div>';
          }).join('');
          grid.querySelectorAll('.image-asset-card').forEach(function(card) {
            card.addEventListener('click', function() {
              var imgEl = document.getElementById('ed-image');
              if (imgEl) imgEl.value = this.dataset.url;
              closeModal();
            });
          });
        })
        .catch(function(err) {
          console.error('Image search error:', err);
          grid.innerHTML = '<div class="fallback-status-msg">Search failed: ' + (err.message || 'unknown error') + '</div>';
        });
      }

      tabButtons.forEach(function(button) {
        button.addEventListener('click', function() {
          tabButtons.forEach(function(btn) { btn.classList.remove('active'); });
          button.classList.add('active');
          selectedProvider = button.getAttribute('data-provider-id') || 'unsplash';
          executeImageFetch();
        });
      });

      searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') executeImageFetch();
      });

      document.getElementById('btn-search-images').addEventListener('click', function() {
        searchInput.value = document.getElementById('ed-image').value || document.getElementById('ed-title').value || 'ai';
        selectedProvider = 'unsplash';
        tabButtons.forEach(function(b) { b.classList.remove('active'); });
        var firstTab = document.querySelector('[data-provider-id="unsplash"]');
        if (firstTab) firstTab.classList.add('active');
        overlay.style.display = 'flex';
        searchInput.focus();
        executeImageFetch();
      });
    }

    // --- Filter Modal ---
    function showFilteredPosts(filter, label) {
      var overlay = document.createElement('div');
      overlay.className = 'filter-modal-overlay';
      var filtered = [];
      if (filter === 'all') filtered = state.posts;
      else if (filter === 'featured') filtered = state.posts.filter(function(p) { return p.featured; });
      else if (filter === 'draft') filtered = state.posts.filter(function(p) { return p.draft; });
      else if (filter === 'popular') filtered = state.posts.filter(function(p) { return p.tags && p.tags.indexOf('popular') !== -1; });
      else if (filter === 'trending') filtered = state.posts.filter(function(p) { return p.tags && p.tags.indexOf('trending') !== -1; });

      var rowsHtml = filtered.map(function(item) {
        var date = item.publishDate ? formatDate(item.publishDate) : '';
        var cats = (item.categories || []).map(function(c) { return '<span class="post-cat">' + escapeHtml(c) + '</span>'; }).join('');
        var tags = (item.tags || []).slice(0, 3).map(function(t) { return '<span style="font-size:11px;color:#64748B">' + escapeHtml(t) + '</span>'; }).join('');
        var draftBadge = item.draft ? '<span class="post-draft-badge">Draft</span>' : '';
        return '<tr>' +
          '<td><div class="post-title">' + escapeHtml(item.title) + draftBadge + '</div></td>' +
          '<td><div class="post-cats">' + cats + '</div></td>' +
          '<td><div class="post-cats">' + tags + '</div></td>' +
          '<td class="post-date">' + date + '</td>' +
          '<td>' + (item.slug ? '<button class="btn-edit filter-edit" data-slug="' + item.slug + '">Edit</button>' : '') + '</td>' +
        '</tr>';
      }).join('');

      overlay.innerHTML = '<div class="filter-modal">' +
        '<div class="filter-modal-header">' +
          '<h3>' + label + ' (' + filtered.length + ')</h3>' +
          '<button class="filter-modal-close">&times;</button>' +
        '</div>' +
        '<div class="filter-modal-body">' +
          (filtered.length === 0 ? '<div class="filter-modal-empty">No ' + label.toLowerCase() + ' yet</div>' :
          '<table class="filter-modal-table"><thead><tr>' +
            '<th>Title</th><th>Categories</th><th>Tags</th><th>Date</th><th></th>' +
          '</tr></thead><tbody>' + rowsHtml + '</tbody></table>') +
        '</div>' +
      '</div>';

      function close() { overlay.remove(); }
      overlay.querySelector('.filter-modal-close').addEventListener('click', close);
      overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
      var editBtns = overlay.querySelectorAll('.filter-edit');
      editBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = this.dataset.slug;
          var post = state.posts.find(function(p) { return p.slug === slug; });
          if (post) { state.editingPost = post; state.view = 'editor'; render(); }
          close();
        });
      });
      document.body.appendChild(overlay);
    }

    // --- Post CRUD ---
    async function handleSave() {
      var slugEl = document.getElementById('ed-slug');
      var titleEl = document.getElementById('ed-title');
      var excerptEl = document.getElementById('ed-excerpt');
      var dateEl = document.getElementById('ed-date');
      var authorEl = document.getElementById('ed-author');
      var catsEl = document.getElementById('ed-categories');
      var tagsEl = document.getElementById('ed-tags');
      var imageEl = document.getElementById('ed-image');
      var featuredEl = document.getElementById('ed-featured');
      var draftEl = document.getElementById('ed-draft');
      var bodyEl = document.getElementById('ed-body');

      if (!titleEl || !bodyEl) return;

      var title = titleEl.value.trim();
      if (!title) { showToast('Title is required', 'error'); return; }

      var slug = slugEl.value.trim() || slugify(title);
      if (!slug) { showToast('Could not generate slug', 'error'); return; }

      var saveBtn = document.getElementById('btn-save-post');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      try {
        var attrs = {
          title: title,
          excerpt: excerptEl ? excerptEl.value.trim() : '',
          publishDate: dateEl ? dateEl.value : new Date().toISOString().split('T')[0],
          featuredImage: imageEl ? imageEl.value.trim() : '',
          featured: featuredEl ? featuredEl.checked : false,
          draft: draftEl ? draftEl.checked : false,
          categories: (catsEl ? catsEl.value : '').split(',').map(function(s) { return s.trim(); }).filter(Boolean),
          tags: (tagsEl ? tagsEl.value : '').split(',').map(function(s) { return s.trim(); }).filter(Boolean),
          author: authorEl ? authorEl.value.trim() || 'Aethel' : 'Aethel',
        };
        // ghSaveFile auto-retries on SHA mismatch, so just pass current SHA
        if (state.editingPost && state.editingPost.sha) {
          attrs._sha = state.editingPost.sha;
        }
        var body = bodyEl.value;
        await AdminAPI.savePost(slug, attrs, body);
        try { sessionStorage.removeItem('aa_posts_cache'); } catch(e) {}
        _cache.posts = 0;
        showToast('Post saved! Rebuilding site...', 'success');
        state.posts = state.posts.map(function(p) {
          if (p.slug === slug) {
            return { slug: slug, name: slug + '.md', sha: attrs._sha || p.sha, title: attrs.title, excerpt: attrs.excerpt, publishDate: attrs.publishDate, categories: attrs.categories, tags: attrs.tags, draft: attrs.draft, featured: attrs.featured, author: attrs.author, featuredImage: attrs.featuredImage, body: body };
          }
          if (p.slug === state.editingPost && state.editingPost.slug && state.editingPost.slug !== slug) {
            return null;
          }
          return p;
        }).filter(Boolean);
        render();
      } catch(e) {
        showToast('Error saving: ' + e.message, 'error');
        saveBtn.disabled = false;
        saveBtn.textContent = state.editingPost ? 'Save Changes' : 'Create Post';
      }
    }

    async function handleDelete(post) {
      try {
        await AdminAPI.deletePost(post.slug, post.sha);
        showToast('Post deleted. Rebuilding...', 'success');
        _cache.posts = 0;
        state.view = 'list';
        state.posts = state.posts.filter(function(p) { return p.slug !== post.slug; });
        render();
      } catch(e) {
        showToast('Error deleting: ' + e.message, 'error');
      }
    }

    // Message actions
    window.APP = {
      toggleMessageRead: function(idx) {
        if (!state.messages || !state.messages.messages[idx]) return;
        state.messages.messages[idx].read = !state.messages.messages[idx].read;
        AdminAPI.saveMessages(state.messages).then(function(newSha) {
          if (newSha) state.messages._sha = newSha;
          render();
          showToast('Message updated', 'success');
        }).catch(function(err) {
          showToast('Error: ' + err.message, 'error');
        });
      },
      deleteMessage: function(idx) {
        if (!state.messages || !state.messages.messages[idx]) return;
        if (!confirm('Delete this message?')) return;
        state.messages.messages.splice(idx, 1);
        AdminAPI.saveMessages(state.messages).then(function(newSha) {
          if (newSha) state.messages._sha = newSha;
          render();
          showToast('Message deleted', 'success');
        }).catch(function(err) {
          showToast('Error: ' + err.message, 'error');
        });
      },
      runDiagnostics: runDiagnostics,
    };

    // --- Diagnostics ---
    async function runDiagnostics() {
      state.view = 'diagnostics';
      state.diag = {};
      render();

      var diag = {};
      var pat = AdminAPI.getPat();
      diag.patPreview = pat ? pat.substring(0, 8) : '';

      // 1. Check PAT
      try {
        var userRes = await fetch('https://api.github.com/user', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' }
        });
        diag.patOk = userRes.ok;
        if (userRes.ok) {
          var userData = await userRes.json();
          diag.patUser = userData.login;
        }
      } catch(e) { diag.patOk = false; }
      diag.patDone = true;
      state.diag = diag;
      render();

      // 2. Check repo access
      try {
        var repoRes = await fetch('https://api.github.com/repos/greatokon98/aethel-ai', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' }
        });
        diag.repoOk = repoRes.ok;
      } catch(e) { diag.repoOk = false; }
      diag.repoDone = true;
      state.diag = diag;
      render();

      // 3. Check posts
      try {
        var postsData = await AdminAPI.listPosts();
        diag.postsCount = postsData.length;
        diag.postsOk = true;
      } catch(e) {
        diag.postsCount = 0;
        diag.postsOk = false;
        diag.postsError = e.message;
      }
      diag.postsDone = true;
      state.diag = diag;
      render();

      // 4. Check data files
      try {
        var msgs = await AdminAPI.loadMessages();
        diag.messagesOk = msgs && msgs.messages !== undefined;
      } catch(e) { diag.messagesOk = false; }
      try {
        var sq = await AdminAPI.loadSearchQueries();
        diag.searchOk = sq && sq.queries !== undefined;
      } catch(e) { diag.searchOk = false; }
      diag.dataDone = true;

      // 5. Recommendation
      var recs = [];
      if (!diag.patOk) recs.push('GitHub token is invalid or missing. Go to Settings → Security → Developer settings → Personal access tokens to create one with <strong>repo</strong> scope.');
      if (!diag.repoOk) recs.push('Cannot access the repository. Ensure your token has <strong>repo</strong> scope.');
      if (diag.postsOk) recs.push('Posts directory accessible. <strong>' + diag.postsCount + ' posts</strong> found.');
      if (!diag.messagesOk) recs.push('Messages file not found. It will be created automatically when the first message is received.');
      if (!diag.searchOk) recs.push('Search queries file not found. It will be created automatically when the first search is performed.');
      if (diag.patOk && diag.repoOk && diag.postsOk) recs.push('<strong>All systems operational.</strong> The admin panel is connected and ready.');
      diag.recommendation = recs.length ? recs.join('<br /><br />') : 'All checks passed. Everything looks good.';

      state.diag = diag;
      render();
    }

    // --- Settings save ---
    async function saveSettings() {
      var s = state.settings || JSON.parse(JSON.stringify(AdminAPI.defaultSettings));

      s.site.title = document.getElementById('set-title').value.trim() || s.site.title;
      s.site.tagline = document.getElementById('set-tagline').value.trim() || s.site.tagline;
      s.site.description = document.getElementById('set-description').value.trim() || s.site.description;
      s.site.copyright = document.getElementById('set-copyright').value.trim() || s.site.copyright;

      var navLabelEls = qsa('.settings-nav-label');
      var navUrlEls = qsa('.settings-nav-url');
      s.navigation.links = [];
      for (var ni = 0; ni < navLabelEls.length; ni++) {
        var label = navLabelEls[ni].value.trim();
        var url = navUrlEls[ni].value.trim();
        if (label && url) s.navigation.links.push({ label: label, url: url });
      }

      s.social.twitter = document.getElementById('set-twitter').value.trim() || '#';
      s.social.github = document.getElementById('set-github').value.trim() || '#';
      s.social.linkedin = document.getElementById('set-linkedin').value.trim() || '#';

      s.design.accentColor = document.getElementById('set-accent-text').value.trim() || '#3B82F6';
      s.design.accentHover = document.getElementById('set-accent-hover-text').value.trim() || '#2563EB';
      s.design.primaryColor = document.getElementById('set-primary-text').value.trim() || '#0F1E36';

      s.content.heroCount = parseInt(document.getElementById('set-hero-count').value) || 3;
      s.content.postsPerPage = parseInt(document.getElementById('set-posts-per-page').value) || 12;
      s.content.sidebarWidgets = {
        search: document.getElementById('set-widget-search').checked,
        trending: document.getElementById('set-widget-trending').checked,
        categories: document.getElementById('set-widget-categories').checked,
        popular: document.getElementById('set-widget-popular').checked,
        newsletter: document.getElementById('set-widget-newsletter').checked,
      };

      try {
        var newSha = await AdminAPI.saveSettings(s);
        if (newSha) s._sha = newSha;
        state.settings = s;
        showToast('Settings saved! Rebuilding site...', 'success');
      } catch(e) {
        showToast('Error saving settings: ' + e.message, 'error');
      }
    }

    // --- Init ---
    async function init() {
      render();
      var pat = AdminAPI.getPat();
      if (!pat) {
        window.location.href = '/admin/';
        return;
      }
      var savedTab;
      try { savedTab = sessionStorage.getItem('aa_active_tab'); } catch(e) {}
      var allowedTabs = ['dashboard','list','trending','popular','messages','search','automation','settings','diagnostics','editor'];
      if (savedTab && allowedTabs.indexOf(savedTab) !== -1) {
        if (savedTab === 'editor') {
          try {
            var savedPost = sessionStorage.getItem('aa_editing_post');
            if (savedPost) state.editingPost = JSON.parse(savedPost);
          } catch(e) {}
        }
        switchView(savedTab);
      } else {
        loadPosts();
      }
    }

    // Marked preview update
    window.updatePreview = function() {
      var body = document.getElementById('ed-body');
      var preview = document.getElementById('ed-preview');
      if (body && preview) {
        try { preview.innerHTML = marked.parse(body.value); } catch(e) { preview.textContent = body.value; }
      }
    };

    // Load marked from CDN
    var script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/marked@15.0.7/marked.min.js';
    script.onload = init;
    document.head.appendChild(script);
  })();
</script>

</AdminLayout>
