    // --- Diagnostics ---
    function renderDiagnostics() {
      var d = state.diag || {};
      var badge = function(ok, text) { return '<span class="diag-badge diag-badge--' + (ok ? 'ok' : 'fail') + '">' + (text || (ok ? 'PASS' : 'FAIL')) + '</span>'; };
      var row = function(label, val, badgeHtml) { return '<div class="diag-row"><span class="diag-label">' + label + '</span>' + (badgeHtml ? badgeHtml : '<span class="diag-value">' + val + '</span>') + '</div>'; };

      return '<div class="diag">' +
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">' +
          '<h2>Diagnostics</h2>' +
          '<button class="admin-header__btn admin-header__btn--primary" onclick="APP.runDiagnostics()">Run Again</button>' +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>GitHub Token</h3>' +
          (d.patDone ? (
            row('Token Status', d.patOk ? badge(true, 'Valid') : badge(false, 'Invalid or missing')) +
            (d.patPreview ? row('Token Preview', escapeHtml(d.patPreview + '...')) : '') +
            (d.patUser ? row('Authenticated as', escapeHtml(d.patUser)) : '')
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking token...</div>') +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>REPO ACCESS</h3>' +
          (d.repoDone ? (
            row('Repository', 'greatokon98/aethel-ai') +
            row('Status', d.repoOk ? badge(true, 'Accessible') : badge(false, 'Not accessible'))
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking repo access...</div>') +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>Posts Directory</h3>' +
          (d.postsDone ? (
            row('Files Found', String(d.postsCount)) +
            row('Status', d.postsOk ? badge(true, 'OK') : badge(false, d.postsError))
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking posts...</div>') +
        '</div>' +

        '<div class="diag-section">' +
          '<h3>Data Files</h3>' +
          (d.dataDone ? (
            row('messages.json', d.messagesOk ? badge(true, 'Accessible') : badge(false, 'Not found or error')) +
            row('search-queries.json', d.searchOk ? badge(true, 'Accessible') : badge(false, 'Not found or error'))
          ) : '<div class="diag-progress"><div class="spinner"></div> Checking data files...</div>') +
        '</div>' +

        '<div class="diag-section" style="background:#EFF6FF;border-color:#93C5FD">' +
          '<h3 style="color:#1D4ED8">Recommendation</h3>' +
          '<div style="font-size:14px;line-height:1.6">' +
            (d.recommendation || 'Run diagnostics to check the system status.') +
          '</div>' +
        '</div>' +
      '</div>';
    }

    // --- Main render ---
    function render() {
      var app = document.getElementById('app');
      if (!app) return;
      var html = '';

      // Header
      var userData;
      try { userData = JSON.parse(localStorage.getItem('aa_user')); } catch(e) {}
      var userName = (userData && userData.name) || 'Admin';
      html += '<header class="admin-header">' +
        '<a href="/" class="admin-header__brand">' +
          '<svg width="24" height="24" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="6" fill="#3B82F6"/><path d="M8 22 L11 7 Q11.3 5.5 13 5.5 Q14.7 5.5 15 7 L18 22 L16 22 L15 16.5 H10 L9 22 Z M10.5 14.5 H14.5 L12.5 9.5 Z" fill="white"/></svg>' +
          '<span class="admin-header__brand-text">Aethel_AI</span>' +
        '</a>' +
        '<div class="admin-header__actions">' +
          '<span class="admin-header__user" id="header-user">' + escapeHtml(userName) + '</span>' +
          '<button class="theme-toggle-btn" id="theme-toggle" title="Toggle theme">☀️</button>' +
          '<button class="admin-header__btn" onclick="window.location.href=\'/\'">View Site</button>' +
          '<button class="admin-header__btn" id="btn-logout">Sign Out</button>' +
        '</div>' +
      '</header>';

      // Tab navigation (skip for loading/error)
      if (state.view !== 'loading' && state.view !== 'error') {
        html += renderTabNav();
      }

      // Content
      html += '<div class="admin-container">';
      if (state.view === 'loading') {
        html += renderLoading();
      } else if (state.view === 'error') {
        html += renderError();
      } else if (state.view === 'dashboard') {
        html += renderDashboard();
      } else if (state.view === 'list') {
        html += renderPostList(state.posts);
      } else if (state.view === 'editor') {
        html += renderEditor(state.editingPost);
      } else if (state.view === 'trending') {
        html += renderTrendingList();
      } else if (state.view === 'messages') {
        html += renderMessages();
      } else if (state.view === 'search') {
        html += renderSearchAnalytics();
      } else if (state.view === 'automation') {
        html += renderAutomation();
      } else if (state.view === 'settings') {
        html += renderSettingsForm();
      } else if (state.view === 'diagnostics') {
        html += renderDiagnostics();
      }
      html += '</div>';

      app.innerHTML = html;
      bindEvents();
    }

    // --- Event Binding ---
    function bindEvents() {
      // Theme toggle
      var themeBtn = document.getElementById('theme-toggle');
      if (themeBtn) {
        var currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        themeBtn.textContent = currentTheme === 'dark' ? '🌙' : '☀️';
        themeBtn.addEventListener('click', function() {
          var newTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('theme', newTheme);
          themeBtn.textContent = newTheme === 'dark' ? '🌙' : '☀️';
        });
      }

      // Sign out
      var logoutBtn = document.getElementById('btn-logout');
      if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
          AdminAPI.removePat();
          window.location.href = '/admin/';
        });
      }

      // New post
      var newBtn = document.getElementById('btn-new-post');
      if (newBtn) {
        newBtn.addEventListener('click', function() {
          state.view = 'editor';
          state.editingPost = null;
          render();
        });
      }

      // Edit buttons
      qsa('.btn-edit').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = this.dataset.slug;
          var post = state.posts.find(function(p) { return p.slug === slug; });
          if (post) {
            state.editingPost = JSON.parse(JSON.stringify(post));
            state.view = 'editor';
            render();
          }
        });
      });

      // Delete buttons
      qsa('.btn-delete').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var slug = this.dataset.slug;
          var title = this.dataset.title;
          if (confirm('Delete "' + title + '"? This cannot be undone.')) {
            var post = state.posts.find(function(p) { return p.slug === slug; });
            if (post) handleDelete(post);
          }
        });
      });

      // Cancel edit
      var cancelBtn = document.getElementById('btn-cancel-edit');
      if (cancelBtn) {
        cancelBtn.addEventListener('click', function() { state.view = 'list'; render(); });
      }

      // Save post
      var saveBtn = document.getElementById('btn-save-post');
      if (saveBtn) {
        saveBtn.addEventListener('click', handleSave);
      }

      // Editor delete
      var delBtn = document.getElementById('btn-editor-delete');
      if (delBtn) {
        delBtn.addEventListener('click', function() {
          if (state.editingPost && confirm('Delete "' + state.editingPost.title + '"? This cannot be undone.')) {
            handleDelete(state.editingPost);
          }
        });
      }

      // Tab navigation
      qsa('.admin-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
          var view = this.dataset.tab;
          switchView(view);
        });
      });

      // Trending manual buttons
      qsa('.trending-manual').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var title = this.dataset.title;
          var slug = this.dataset.slug;
          state.editingPost = {
            title: title,
            slug: slug,
            excerpt: '',
            body: '<!-- Rewrite this trending story in your own voice. Add insight, make it yours. -->\n\n## Key Points\n\n- \n- \n- \n\n## The Story\n\n\n\n## Why It Matters\n\n',
            categories: ['AI News'],
            tags: ['trending'],
            author: 'Aethel',
            featured: false,
            featuredImage: '',
            publishDate: new Date().toISOString().split('T')[0],
            sha: null,
          };
          state.view = 'editor';
          render();
        });
      });

      // Trending auto-generate buttons
      qsa('.trending-auto').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var title = this.dataset.title;
          var slug = this.dataset.slug;
          var btnEl = this;
          btnEl.disabled = true;
          btnEl.textContent = 'Generating...';
          try {
            var result = await AdminAPI.generatePost(title);
            var content = result.content;
            state.editingPost = {
              title: content.title || title,
              slug: slugify(content.title || title),
              excerpt: content.excerpt || '',
              body: content.body || '',
              categories: content.category ? [content.category] : ['AI News'],
              tags: content.tags || ['trending'],
              author: 'Aethel',
              featured: false,
              featuredImage: '',
              publishDate: new Date().toISOString().split('T')[0],
              sha: null,
            };
            state.view = 'editor';
            render();
            showToast('Content generated! Review and publish.', 'success');
          } catch(err) {
            showToast('Generation failed: ' + err.message, 'error');
            btnEl.disabled = false;
            btnEl.textContent = 'Auto Write';
          }
        });
      });

      // Refresh trending
      var refreshBtn = document.getElementById('btn-refresh-trending');
      if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
          state.trendingItems = [];
          render();
          loadTrending();
        });
      }

      // Settings: add nav link
      var addNavBtn = document.getElementById('btn-add-nav-link');
      if (addNavBtn) {
        addNavBtn.addEventListener('click', function() {
          var list = document.getElementById('settings-nav-list');
          if (!list) return;
          var div = document.createElement('div');
          div.className = 'settings-nav-row';
          div.innerHTML = '<input type="text" class="settings-nav-label" value="" placeholder="Label" />' +
            '<input type="text" class="settings-nav-url" value="" placeholder="/page" />' +
            '<button class="settings-nav-remove">×</button>';
          list.appendChild(div);
          div.querySelector('.settings-nav-remove').addEventListener('click', function() { div.remove(); });
        });
      }

      // Settings: remove nav link
      qsa('.settings-nav-remove').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var row = this.closest('.settings-nav-row');
          if (row) row.remove();
        });
      });

      // Settings: color picker sync
      function syncColor(pickerId, textId) {
        var picker = document.getElementById(pickerId);
        var text = document.getElementById(textId);
        if (picker && text) {
          picker.addEventListener('input', function() { text.value = this.value; });
          text.addEventListener('input', function() { picker.value = this.value; });
        }
      }
      syncColor('set-accent', 'set-accent-text');
      syncColor('set-accent-hover', 'set-accent-hover-text');
      syncColor('set-primary', 'set-primary-text');

      // Settings: save
      var saveSettingsBtn = document.getElementById('btn-save-settings');
      if (saveSettingsBtn) {
        saveSettingsBtn.addEventListener('click', saveSettings);
      }

      // Automation: run pipeline
      var runBtn = document.getElementById('btn-run-automation');
      if (runBtn) {
        runBtn.addEventListener('click', function() {
          if (confirm('Trigger the auto-content pipeline now? This will generate new posts via Gemini.')) {
            var btn = this;
            btn.disabled = true;
            btn.textContent = 'Running...';
            AdminAPI.triggerWorkflow()
              .then(function() {
                showToast('Pipeline triggered! Check back in a few minutes.', 'success');
                btn.disabled = false;
                btn.textContent = '▶ Run Pipeline';
                // Log the run
                loadAutomationRuns();
              })
              .catch(function(err) {
                showToast('Error: ' + err.message, 'error');
                btn.disabled = false;
                btn.textContent = '▶ Run Pipeline';
              });
          }
        });
      }

      // Automation: refresh
      var refreshAutoBtn = document.getElementById('btn-refresh-automation');
      if (refreshAutoBtn) {
        refreshAutoBtn.addEventListener('click', function() {
          loadAutomationRuns();
        });
      }
    }

    // --- View switching ---
    function switchView(view) {
      state.view = view;
      if (view === 'dashboard') {
        loadDashboard();
      } else if (view === 'trending' && state.trendingItems.length === 0) {
        loadTrending();
      } else if (view === 'settings') {
        loadSettings();
      } else if (view === 'messages') {
        loadMessages();
      } else if (view === 'search') {
        loadSearchData();
      } else if (view === 'automation') {
        loadAutomationRuns();
      } else {
        render();
      }
    }

    // --- Data Loading ---
    async function loadDashboard() {
      render();
      try {
        state.posts = await AdminAPI.listPosts();
      } catch(e) {}
      try {
        state.messages = await AdminAPI.loadMessages();
      } catch(e) {}
      try {
        state.searchData = await AdminAPI.loadSearchQueries();
      } catch(e) {}
      try {
        state.automationRuns = await AdminAPI.loadAutomationRuns();
      } catch(e) {}
      render();
    }

    async function loadPosts() {
      state.view = 'loading';
      render();
      try {
        state.posts = await AdminAPI.listPosts();
        state.view = 'list';
      } catch(e) {
        state.view = 'error';
        state.error = e.message;
      }
      render();
    }

    async function loadTrending() {
      state.trendingItems = [];
      render();
      try {
        state.trendingItems = await AdminAPI.fetchTrending();
      } catch(e) {
        state.trendingItems = [];
      }
      render();
    }

    async function loadSettings() {
      render();
      try {
        state.settings = await AdminAPI.loadSettings();
      } catch(e) {
        state.settings = JSON.parse(JSON.stringify(AdminAPI.defaultSettings));
      }
      render();
    }

    async function loadMessages() {
      render();
      try {
        state.messages = await AdminAPI.loadMessages();

        // Sync pending messages from localStorage
        try {
          var pending = JSON.parse(localStorage.getItem('aa_pending_messages') || '[]');
          if (pending.length > 0) {
            var existing = state.messages.messages || [];
            var existingIds = {};
            existing.forEach(function(m) { existingIds[m.id] = true; });
            var newMsgs = pending.filter(function(m) { return !existingIds[m.id]; });
            if (newMsgs.length > 0) {
              existing = existing.concat(newMsgs);
              state.messages.messages = existing;
              var newSha = await AdminAPI.saveMessages(state.messages);
              if (newSha) state.messages._sha = newSha;
              localStorage.removeItem('aa_pending_messages');
            }
          }
        } catch(e) {}
      } catch(e) {
        state.messages = { messages: [], _sha: null };
      }
      render();
    }

    async function loadSearchData() {
      render();
      try {
        state.searchData = await AdminAPI.loadSearchQueries();

        // Sync pending search queries from localStorage
        try {
          var pending = JSON.parse(localStorage.getItem('aa_search_queries') || '[]');
          if (pending.length > 0) {
            var existing = state.searchData.queries || [];
            existing = existing.concat(pending);
            state.searchData.queries = existing;
            var newSha = await AdminAPI.saveSearchQueries(state.searchData);
            if (newSha) state.searchData._sha = newSha;
            localStorage.removeItem('aa_search_queries');
          }
        } catch(e) {}
      } catch(e) {
        state.searchData = { queries: [], _sha: null };
      }
      render();
    }

    async function loadAutomationRuns() {
      render();
      try {
        state.automationRuns = await AdminAPI.loadAutomationRuns();
      } catch(e) {
        state.automationRuns = { runs: [], _sha: null };
      }
      try {
        state.workflowRuns = await AdminAPI.getWorkflowStatus();
      } catch(e) {
        state.workflowRuns = [];
      }
      render();
    }

    // --- Post CRUD ---
    async function handleSave() {
      var slugEl = document.getElementById('ed-slug');
      var titleEl = document.getElementById('ed-title');
      var excerptEl = document.getElementById('ed-excerpt');
      var dateEl = document.getElementById('ed-date');
      var authorEl = document.getElementById('ed-author');
      var catsEl = document.getElementById('ed-categories');
      var tagsEl = document.getElementById('ed-tags');
      var imageEl = document.getElementById('ed-image');
      var featuredEl = document.getElementById('ed-featured');
      var bodyEl = document.getElementById('ed-body');

      if (!titleEl || !bodyEl) return;

      var title = titleEl.value.trim();
      if (!title) { showToast('Title is required', 'error'); return; }

      var slug = slugEl.value.trim() || slugify(title);
      if (!slug) { showToast('Could not generate slug', 'error'); return; }

      var saveBtn = document.getElementById('btn-save-post');
      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      try {
        var attrs = {
          title: title,
          excerpt: excerptEl ? excerptEl.value.trim() : '',
          publishDate: dateEl ? dateEl.value : new Date().toISOString().split('T')[0],
          featuredImage: imageEl ? imageEl.value.trim() : '',
          featured: featuredEl ? featuredEl.checked : false,
          categories: (catsEl ? catsEl.value : '').split(',').map(function(s) { return s.trim(); }).filter(Boolean),
          tags: (tagsEl ? tagsEl.value : '').split(',').map(function(s) { return s.trim(); }).filter(Boolean),
          author: authorEl ? authorEl.value.trim() || 'Aethel' : 'Aethel',
        };
        if (state.editingPost && state.editingPost.sha) {
          attrs._sha = state.editingPost.sha;
        }
        var body = bodyEl.value;
        await AdminAPI.savePost(slug, attrs, body);
        showToast('Post saved! Rebuilding site...', 'success');
        state.view = 'list';
        render();
        loadPosts();
      } catch(e) {
        showToast('Error saving: ' + e.message, 'error');
        saveBtn.disabled = false;
        saveBtn.textContent = state.editingPost ? 'Save Changes' : 'Create Post';
      }
    }

    async function handleDelete(post) {
      try {
        await AdminAPI.deletePost(post.slug, post.sha);
        showToast('Post deleted. Rebuilding...', 'success');
        state.view = 'list';
        render();
        loadPosts();
      } catch(e) {
        showToast('Error deleting: ' + e.message, 'error');
      }
    }

    // Message actions
    window.APP = {
      toggleMessageRead: function(idx) {
        if (!state.messages || !state.messages.messages[idx]) return;
        state.messages.messages[idx].read = !state.messages.messages[idx].read;
        AdminAPI.saveMessages(state.messages).then(function(newSha) {
          if (newSha) state.messages._sha = newSha;
          render();
          showToast('Message updated', 'success');
        }).catch(function(err) {
          showToast('Error: ' + err.message, 'error');
        });
      },
      deleteMessage: function(idx) {
        if (!state.messages || !state.messages.messages[idx]) return;
        if (!confirm('Delete this message?')) return;
        state.messages.messages.splice(idx, 1);
        AdminAPI.saveMessages(state.messages).then(function(newSha) {
          if (newSha) state.messages._sha = newSha;
          render();
          showToast('Message deleted', 'success');
        }).catch(function(err) {
          showToast('Error: ' + err.message, 'error');
        });
      },
      runDiagnostics: runDiagnostics,
    };

    // --- Diagnostics ---
    async function runDiagnostics() {
      state.view = 'diagnostics';
      state.diag = {};
      render();

      var diag = {};
      var pat = AdminAPI.getPat();
      diag.patPreview = pat ? pat.substring(0, 8) : '';

      // 1. Check PAT
      try {
        var userRes = await fetch('https://api.github.com/user', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' }
        });
        diag.patOk = userRes.ok;
        if (userRes.ok) {
          var userData = await userRes.json();
          diag.patUser = userData.login;
        }
      } catch(e) { diag.patOk = false; }
      diag.patDone = true;
      state.diag = diag;
      render();

      // 2. Check repo access
      try {
        var repoRes = await fetch('https://api.github.com/repos/greatokon98/aethel-ai', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' }
        });
        diag.repoOk = repoRes.ok;
      } catch(e) { diag.repoOk = false; }
      diag.repoDone = true;
      state.diag = diag;
      render();

      // 3. Check posts
      try {
        var postsData = await AdminAPI.listPosts();
        diag.postsCount = postsData.length;
        diag.postsOk = true;
      } catch(e) {
        diag.postsCount = 0;
        diag.postsOk = false;
        diag.postsError = e.message;
      }
      diag.postsDone = true;
      state.diag = diag;
      render();

      // 4. Check data files
      try {
        var msgs = await AdminAPI.loadMessages();
        diag.messagesOk = msgs && msgs.messages !== undefined;
      } catch(e) { diag.messagesOk = false; }
      try {
        var sq = await AdminAPI.loadSearchQueries();
        diag.searchOk = sq && sq.queries !== undefined;
      } catch(e) { diag.searchOk = false; }
      diag.dataDone = true;

      // 5. Recommendation
      var recs = [];
      if (!diag.patOk) recs.push('GitHub token is invalid or missing. Go to Settings → Security → Developer settings → Personal access tokens to create one with <strong>repo</strong> scope.');
      if (!diag.repoOk) recs.push('Cannot access the repository. Ensure your token has <strong>repo</strong> scope.');
      if (diag.postsOk) recs.push('Posts directory accessible. <strong>' + diag.postsCount + ' posts</strong> found.');
      if (!diag.messagesOk) recs.push('Messages file not found. It will be created automatically when the first message is received.');
      if (!diag.searchOk) recs.push('Search queries file not found. It will be created automatically when the first search is performed.');
      if (diag.patOk && diag.repoOk && diag.postsOk) recs.push('<strong>All systems operational.</strong> The admin panel is connected and ready.');
      diag.recommendation = recs.length ? recs.join('<br /><br />') : 'All checks passed. Everything looks good.';

      state.diag = diag;
      render();
    }

    // --- Settings save ---
    async function saveSettings() {
      var s = state.settings || JSON.parse(JSON.stringify(AdminAPI.defaultSettings));

      s.site.title = document.getElementById('set-title').value.trim() || s.site.title;
      s.site.tagline = document.getElementById('set-tagline').value.trim() || s.site.tagline;
      s.site.description = document.getElementById('set-description').value.trim() || s.site.description;
      s.site.copyright = document.getElementById('set-copyright').value.trim() || s.site.copyright;

      var navLabelEls = qsa('.settings-nav-label');
      var navUrlEls = qsa('.settings-nav-url');
      s.navigation.links = [];
      for (var ni = 0; ni < navLabelEls.length; ni++) {
        var label = navLabelEls[ni].value.trim();
        var url = navUrlEls[ni].value.trim();
        if (label && url) s.navigation.links.push({ label: label, url: url });
      }

      s.social.twitter = document.getElementById('set-twitter').value.trim() || '#';
      s.social.github = document.getElementById('set-github').value.trim() || '#';
      s.social.linkedin = document.getElementById('set-linkedin').value.trim() || '#';

      s.design.accentColor = document.getElementById('set-accent-text').value.trim() || '#3B82F6';
      s.design.accentHover = document.getElementById('set-accent-hover-text').value.trim() || '#2563EB';
      s.design.primaryColor = document.getElementById('set-primary-text').value.trim() || '#0F1E36';

      s.content.heroCount = parseInt(document.getElementById('set-hero-count').value) || 3;
      s.content.postsPerPage = parseInt(document.getElementById('set-posts-per-page').value) || 12;
      s.content.sidebarWidgets = {
        search: document.getElementById('set-widget-search').checked,
        trending: document.getElementById('set-widget-trending').checked,
        categories: document.getElementById('set-widget-categories').checked,
        popular: document.getElementById('set-widget-popular').checked,
        newsletter: document.getElementById('set-widget-newsletter').checked,
      };

      try {
        var newSha = await AdminAPI.saveSettings(s);
        if (newSha) s._sha = newSha;
        state.settings = s;
        showToast('Settings saved! Rebuilding site...', 'success');
      } catch(e) {
        showToast('Error saving settings: ' + e.message, 'error');
      }
    }

    // --- Init ---
    async function init() {
      render();
      var pat = AdminAPI.getPat();
      if (!pat) {
        window.location.href = '/admin/';
        return;
      }
      loadPosts();
    }

    // Marked preview update
    window.updatePreview = function() {
      var body = document.getElementById('ed-body');
      var preview = document.getElementById('ed-preview');
      if (body && preview) {
        try { preview.innerHTML = marked.parse(body.value); } catch(e) { preview.textContent = body.value; }
      }
    };

    // Load marked from CDN
    var script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/marked@15.0.7/marked.min.js';
    script.onload = init;
    document.head.appendChild(script);
  })();
</script>
</AdminLayout>
