    async function loadSettings(force) {
      if (!force && _cache.settings && Date.now() - _cache.settings < CACHE_TTL && state.settings) {
        render();
        return;
      }
      render();
      try {
        state.settings = await AdminAPI.loadSettings();
        _cache.settings = Date.now();
      } catch(e) {
        state.settings = JSON.parse(JSON.stringify(AdminAPI.defaultSettings));
      }
      render();
    }

    async function loadMessages(force) {
      if (!force && _cache.messages && Date.now() - _cache.messages < CACHE_TTL && state.messages) {
        render();
        return;
      }
      render();
      try {
        state.messages = await AdminAPI.loadMessages();
        _cache.messages = Date.now();

        // Sync pending messages from localStorage
        try {
          var pending = JSON.parse(localStorage.getItem('aa_pending_messages') || '[]');
          if (pending.length > 0) {
            var existing = state.messages.messages || [];
            var existingIds = {};
            existing.forEach(function(m) { existingIds[m.id] = true; });
            var newMsgs = pending.filter(function(m) { return !existingIds[m.id]; });
            if (newMsgs.length > 0) {
              existing = existing.concat(newMsgs);
              state.messages.messages = existing;
              var newSha = await AdminAPI.saveMessages(state.messages);
              if (newSha) state.messages._sha = newSha;
              localStorage.removeItem('aa_pending_messages');
            }
          }
        } catch(e) {}
      } catch(e) {
        state.messages = { messages: [], _sha: null };
      }
      render();
    }

    async function loadSearchData(force) {
      if (!force && _cache.search && Date.now() - _cache.search < CACHE_TTL && state.searchData) {
        render();
        return;
      }
      render();
      try {
        state.searchData = await AdminAPI.loadSearchQueries();
        _cache.search = Date.now();

        // Sync pending search queries from localStorage
        try {
          var pending = JSON.parse(localStorage.getItem('aa_search_queries') || '[]');
          if (pending.length > 0) {
            var existing = state.searchData.queries || [];
            existing = existing.concat(pending);
            state.searchData.queries = existing;
            var newSha = await AdminAPI.saveSearchQueries(state.searchData);
            if (newSha) state.searchData._sha = newSha;
            localStorage.removeItem('aa_search_queries');
          }
        } catch(e) {}
      } catch(e) {
        state.searchData = { queries: [], _sha: null };
      }
      render();
    }

    async function loadAutomationRuns(force) {
      if (!force && _cache.automation && Date.now() - _cache.automation < CACHE_TTL && state.automationRuns) {
        render();
        return;
      }
      render();
      try {
        state.automationRuns = await AdminAPI.loadAutomationRuns();
        _cache.automation = Date.now();
      } catch(e) {
        state.automationRuns = { runs: [], _sha: null };
      }
      try {
        state.workflowRuns = await AdminAPI.getWorkflowStatus();
        _cache.workflow = Date.now();
      } catch(e) {
        state.workflowRuns = [];
      }
      render();
    }

