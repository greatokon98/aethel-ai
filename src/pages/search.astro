---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getConfig } from '../lib/site-config';
import { fetchTrendingNews } from '../lib/trending';
import fs from 'node:fs';
import path from 'node:path';
import parseFrontmatter from 'front-matter';

const postsDir = path.resolve('src/content/posts');
const files = fs.readdirSync(postsDir).filter((f) => f.endsWith('.md'));

function getSlug(file: string) {
  return file.replace(/\.md$/, '');
}

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const allPosts = files
  .map((file) => {
    const content = fs.readFileSync(path.join(postsDir, file), 'utf-8');
    const { attributes, body } = parseFrontmatter(content);
    return {
      title: attributes.title as string || '',
      excerpt: attributes.excerpt as string || '',
      publishDate: (attributes.publishDate as string) || '',
      featuredImage: attributes.featuredImage as string || '',
      categories: (attributes.categories as string[]) || [],
      tags: (attributes.tags as string[]) || [],
      author: (attributes.author as string) || 'Aethel',
      slug: getSlug(file),
      readingTime: getReadingTime(body),
      body: body.slice(0, 1000),
    };
  })
  .sort((a, b) => {
    const da = new Date(a.publishDate).getTime();
    const db = new Date(b.publishDate).getTime();
    return db - da;
  });

const allCategories = [...new Set(allPosts.flatMap((p) => p.categories))];
const trendingPosts = allPosts.filter((p) => p.tags && p.tags.includes('trending'));
const trending = await fetchTrendingNews();
const popularPosts = allPosts.filter((p) => p.tags && p.tags.includes('popular'));
const config = getConfig();
const siteTitle = config?.site?.title || 'Aethel_AI';

const searchScript = [
  'var SEARCH_DATA = ' + JSON.stringify(allPosts) + ';',
  '(function() {',
  '  var data = SEARCH_DATA;',
  '  var grid = document.getElementById("results-grid");',
  '  var title = document.getElementById("results-title");',
  '  var noResults = document.getElementById("no-results");',
  '  var noResultsMsg = document.getElementById("no-results-msg");',
  '  var suggestions = document.getElementById("suggestions");',
  '  var input = document.getElementById("search-input");',
  '  var form = document.getElementById("search-form");',
  '',
  '  var allCats = [];',
  '  data.forEach(function(p) {',
  '    (p.categories || []).forEach(function(c) {',
  '      if (allCats.indexOf(c) === -1) allCats.push(c);',
  '    });',
  '  });',
  '',
  '  function timeAgo(dateStr) {',
  '    var d = new Date(dateStr);',
  '    var diff = Date.now() - d.getTime();',
  '    var days = Math.floor(diff / 86400000);',
  '    if (days === 0) return "Today";',
  '    if (days === 1) return "Yesterday";',
  '    if (days < 7) return days + " days ago";',
  '    if (days < 30) return Math.floor(days / 7) + " weeks ago";',
  '    return d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });',
  '  }',
  '',
  '  function esc(s) {',
  '    var d = document.createElement("div");',
  '    d.appendChild(document.createTextNode(s));',
  '    return d.innerHTML;',
  '  }',
  '',
  '  function render(posts) {',
  '    if (posts.length === 0) {',
  '      grid.innerHTML = "";',
  '      noResults.style.display = "block";',
  '      return;',
  '    }',
  '    noResults.style.display = "none";',
  '    var h = "";',
  '    for (var i = 0; i < posts.length; i++) {',
  '      var p = posts[i];',
  '      var cats = (p.categories || []).map(function(c) {',
  '        var s = c.toLowerCase().replace(/\\s+/g, "-");',
  '        return \'<a href="/category/\' + s + \'" class="search-result-cat">\' + esc(c) + "</a>";',
  '      }).join("");',
  '      if (p.featuredImage) {',
  '        h += \'<article class="search-result-card">\';',
  '        h += \'<a href="/posts/\' + p.slug + \'" class="search-result-img-link">\';',
  '        h += \'<img src="\' + p.featuredImage + \'" alt="\' + esc(p.title) + \'" class="search-result-img" loading="lazy" />\';',
  '        h += "</a>";',
  '      } else {',
  '        h += \'<article class="search-result-card">\';',
  '      }',
  '      h += \'<div class="search-result-body">\';',
  '      h += \'<div class="search-result-meta"><span class="search-result-date">\' + timeAgo(p.publishDate) + \'</span><span class="search-result-reading">\' + p.readingTime + " min read</span></div>";',
  '      h += \'<h3 class="search-result-title"><a href="/posts/\' + p.slug + \'">\' + esc(p.title) + "</a></h3>";',
  '      h += \'<p class="search-result-excerpt">\' + esc(p.excerpt) + "</p>";',
  '      if (cats) h += \'<div class="search-result-cats">\' + cats + "</div>";',
  '      h += "</div></article>";',
  '    }',
  '    grid.innerHTML = h;',
  '  }',
  '',
  '  function doSearch(q) {',
  '    var t = q.trim().toLowerCase();',
  '    if (!t) {',
  '      title.textContent = "Search all articles";',
  '      grid.innerHTML = "";',
  '      noResults.style.display = "none";',
  '      return;',
  '    }',
  '    var results = [];',
  '    for (var i = 0; i < data.length; i++) {',
  '      var p = data[i];',
  '      if (',
  '        p.title.toLowerCase().indexOf(t) !== -1 ||',
  '        p.excerpt.toLowerCase().indexOf(t) !== -1 ||',
  '        p.body.toLowerCase().indexOf(t) !== -1 ||',
  '        (p.categories || []).some(function(c) { return c.toLowerCase().indexOf(t) !== -1; }) ||',
  '        (p.tags || []).some(function(tg) { return tg.toLowerCase().indexOf(t) !== -1; })',
  '      ) {',
  '        results.push(p);',
  '      }',
  '    }',
  '    title.textContent = results.length > 0',
  '      ? "Found " + results.length + " result" + (results.length === 1 ? "" : "s") + \' for "\' + t + \'"\'',
  '      : \'No results for "\' + t + \'"\';',
  '    if (results.length === 0) {',
  '      noResultsMsg.textContent = \'No results for "\' + t + \'". Try a different search term.\';',
  '      suggestions.innerHTML =',
  '        \'<a href="/" class="search-suggestion-link">Browse all posts</a>\' +',
  '        allCats.map(function(c) {',
  '          var s = c.toLowerCase().replace(/\\s+/g, "-");',
  '          return \'<a href="/category/\' + s + \'" class="search-suggestion-link">\' + esc(c) + "</a>";',
  '        }).join("");',
  '      noResults.style.display = "block";',
  '    } else {',
  '      noResults.style.display = "none";',
  '    }',
  '    render(results);',
  '  }',
  '',
  '  form.addEventListener("submit", function(e) {',
  '    e.preventDefault();',
  '    var v = input.value.trim();',
  '    if (!v) return;',
  '    var u = "/search?q=" + encodeURIComponent(v);',
  '    window.history.pushState({ q: v }, "", u);',
  '    doSearch(v);',
  '  });',
  '',
  '  function init() {',
  '    var params = new URLSearchParams(window.location.search);',
  '    var q = params.get("q") || "";',
  '    if (q) { input.value = q; doSearch(q); }',
  '  }',
  '',
  '  window.addEventListener("popstate", function() {',
  '    var params = new URLSearchParams(window.location.search);',
  '    var q = params.get("q") || "";',
  '    input.value = q;',
  '    doSearch(q);',
  '  });',
  '',
  '  init();',
  '})();',
].join('\n');
---

<BaseLayout title={`Search — ${siteTitle}`} description="Search articles on Aethel_AI">
  <section class="section search-page">
    <div class="container">
      <div class="blog-grid__layout">
        <div class="blog-grid__main">
          <div class="search-header">
            <form class="search-page-form" id="search-form" action="/search" method="get">
              <svg class="search-page-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" name="q" id="search-input" placeholder="Search articles..." class="search-page-input" autofocus />
            </form>
          </div>

          <h2 class="search-results-title" id="results-title">Search all articles</h2>

          <div id="no-results" class="search-no-results" style="display:none">
            <p id="no-results-msg">No results found. Try a different search term.</p>
            <div class="search-suggestions" id="suggestions"></div>
          </div>

          <div class="blog-grid__posts" id="results-grid"></div>
        </div>
        <div class="blog-grid__sidebar">
          <Sidebar
            categories={allCategories}
            recentPosts={allPosts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: new Date(p.publishDate),
            }))}
            trendingPosts={trendingPosts}
            trending={trending}
            popularPosts={popularPosts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: new Date(p.publishDate),
            }))}
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script set:html={searchScript}></script>

<style>
  .search-page {
    padding: var(--space-10) 0;
  }

  .search-header {
    margin-bottom: var(--space-8);
  }

  .search-page-form {
    position: relative;
    max-width: 600px;
  }

  .search-page-icon {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-page-input {
    width: 100%;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
    font-family: var(--font-body);
    font-size: var(--text-lg);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .search-page-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .search-page-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-results-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .search-no-results {
    padding: var(--space-10) 0;
    text-align: center;
    color: var(--color-text-secondary);
  }

  .search-no-results p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-6);
  }

  .search-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  .search-suggestion-link {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: border-color var(--transition), background-color var(--transition);
  }

  .search-suggestion-link:hover {
    border-color: var(--color-accent);
    background-color: rgba(59, 130, 246, 0.06);
  }

  .search-result-card {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .search-result-card:last-child {
    border-bottom: none;
  }

  .search-result-img-link {
    flex-shrink: 0;
    width: 180px;
    height: 120px;
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .search-result-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-result-body {
    flex: 1;
    min-width: 0;
  }

  .search-result-meta {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .search-result-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }

  .search-result-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition);
  }

  .search-result-title a:hover {
    color: var(--color-accent);
  }

  .search-result-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .search-result-cats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .search-result-cat {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: opacity var(--transition);
    position: relative;
  }

  .search-result-cat::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 200ms;
  }

  .search-result-cat:hover::after {
    transform: scaleX(1);
  }

  .blog-grid__layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width);
    gap: var(--space-12);
    align-items: start;
  }

  .blog-grid__sidebar {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  .blog-grid__posts {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 1024px) {
    .blog-grid__layout {
      grid-template-columns: 1fr 280px;
      gap: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .blog-grid__layout {
      grid-template-columns: 1fr;
    }
    .blog-grid__sidebar {
      position: static;
    }
    .search-page-input {
      font-size: var(--text-base);
    }
    .search-result-card {
      flex-direction: column;
    }
    .search-result-img-link {
      width: 100%;
      height: 200px;
    }
  }
</style>
