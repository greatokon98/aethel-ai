---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getConfig } from '../lib/site-config';
import { fetchTrendingNews } from '../lib/trending';
import fs from 'node:fs';
import path from 'node:path';
import parseFrontmatter from 'front-matter';

const query = Astro.url.searchParams.get('q') || '';
const trimmed = query.trim().toLowerCase();

const postsDir = path.resolve('src/content/posts');
const files = fs.readdirSync(postsDir).filter((f) => f.endsWith('.md'));

function getSlug(file: string) {
  return file.replace(/\.md$/, '');
}

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const allPosts = files
  .map((file) => {
    const content = fs.readFileSync(path.join(postsDir, file), 'utf-8');
    const { attributes, body } = parseFrontmatter(content);
    return {
      title: attributes.title as string || '',
      excerpt: attributes.excerpt as string || '',
      publishDate: new Date(attributes.publishDate as string || Date.now()),
      featuredImage: attributes.featuredImage as string || '',
      categories: (attributes.categories as string[]) || [],
      tags: (attributes.tags as string[]) || [],
      author: (attributes.author as string) || 'Aethel',
      featured: (attributes.featured as boolean) || false,
      slug: getSlug(file),
      readingTime: getReadingTime(body),
      body: body.toLowerCase(),
    };
  })
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());

const results = trimmed
  ? allPosts.filter((p) =>
      p.title.toLowerCase().includes(trimmed) ||
      p.excerpt.toLowerCase().includes(trimmed) ||
      p.categories.some((c) => c.toLowerCase().includes(trimmed)) ||
      p.tags.some((t) => t.toLowerCase().includes(trimmed)) ||
      p.body.includes(trimmed)
    )
  : [];

const allCategories = [...new Set(allPosts.flatMap((p) => p.categories))];
const trendingPosts = allPosts.filter((p) => p.tags && p.tags.includes('trending'));
const trending = await fetchTrendingNews();
const popularPosts = allPosts.filter((p) => p.tags && p.tags.includes('popular'));
const config = getConfig();
const siteTitle = config?.site?.title || 'Aethel_AI';
---

<BaseLayout title={`Search: ${trimmed || 'All Posts'} — ${siteTitle}`} description={`Search results for ${trimmed || 'all posts'}`}>
  <section class="section search-page">
    <div class="container">
      <div class="blog-grid__layout">
        <div class="blog-grid__main">
          <div class="search-header">
            <form class="search-page-form" action="/search" method="get">
              <svg class="search-page-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" name="q" value={query} placeholder="Search articles..." class="search-page-input" autofocus />
            </form>
          </div>

          {trimmed ? (
            <>
              <h2 class="search-results-title">
                {results.length > 0
                  ? `Found ${results.length} result${results.length === 1 ? '' : 's'} for "${trimmed}"`
                  : `No results for "${trimmed}"`}
              </h2>
              {results.length === 0 && (
                <div class="search-no-results">
                  <p>Try a different search term or browse categories.</p>
                  <div class="search-suggestions">
                    <a href="/" class="search-suggestion-link">Browse all posts</a>
                    {allCategories.map(cat => {
                      const catSlug = cat.toLowerCase().replace(/\s+/g, '-');
                      return <a href={`/category/${catSlug}`} class="search-suggestion-link">{cat}</a>;
                    })}
                  </div>
                </div>
              )}
            </>
          ) : (
            <h2 class="search-results-title">Search all articles</h2>
          )}

          <div class="blog-grid__posts">
            {results.map((post, i) => (
              <div
                class:fade-in={{ true: true, [`fade-in--delay-${Math.min(i + 1, 4)}`]: true }}
              >
                <PostCard
                  title={post.title}
                  excerpt={post.excerpt}
                  publishDate={post.publishDate}
                  slug={post.slug}
                  featuredImage={post.featuredImage}
                  categories={post.categories}
                  author={post.author}
                  readingTime={post.readingTime}
                  featured={false}
                />
              </div>
            ))}
          </div>
        </div>
        <div class="blog-grid__sidebar">
          <Sidebar
            categories={allCategories}
            recentPosts={allPosts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: p.publishDate,
            }))}
            trendingPosts={trendingPosts}
            trending={trending}
            popularPosts={popularPosts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: p.publishDate,
            }))}
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .search-page {
    padding: var(--space-10) 0;
  }

  .search-header {
    margin-bottom: var(--space-8);
  }

  .search-page-form {
    position: relative;
    max-width: 600px;
  }

  .search-page-icon {
    position: absolute;
    left: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-page-input {
    width: 100%;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
    font-family: var(--font-body);
    font-size: var(--text-lg);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    background-color: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .search-page-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .search-page-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-results-title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .search-no-results {
    padding: var(--space-10) 0;
    text-align: center;
    color: var(--color-text-secondary);
  }

  .search-no-results p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-6);
  }

  .search-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  .search-suggestion-link {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    transition: border-color var(--transition), background-color var(--transition);
  }

  .search-suggestion-link:hover {
    border-color: var(--color-accent);
    background-color: rgba(59, 130, 246, 0.06);
  }

  .blog-grid__layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width);
    gap: var(--space-12);
    align-items: start;
  }

  .blog-grid__sidebar {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  .blog-grid__posts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    align-content: start;
  }

  @media (max-width: 1024px) {
    .blog-grid__layout {
      grid-template-columns: 1fr 280px;
      gap: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .blog-grid__layout {
      grid-template-columns: 1fr;
    }
    .blog-grid__sidebar {
      position: static;
    }
    .blog-grid__posts {
      grid-template-columns: 1fr;
    }
    .search-page-input {
      font-size: var(--text-base);
    }
  }
</style>
