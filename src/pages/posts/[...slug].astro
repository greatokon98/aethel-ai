---
import PostLayout from '../../layouts/PostLayout.astro';
import { fetchTrendingNews } from '../../lib/trending';
import fs from 'node:fs';
import path from 'node:path';
import parseFrontmatter from 'front-matter';
import { Marked } from 'marked';

const marked = new Marked();

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

export async function getStaticPaths() {
  const postsDir = path.resolve('src/content/posts');
  if (!fs.existsSync(postsDir)) return [];
  const files = fs.readdirSync(postsDir).filter((f) => f.endsWith('.md'));
  return files.map((file) => ({
    params: { slug: file.replace(/\.md$/, '') },
    props: { file },
  }));
}

export const prerender = true;

const { slug } = Astro.params;

const postsDir = path.resolve('src/content/posts');
const allFiles = fs.readdirSync(postsDir).filter((f) => f.endsWith('.md'));

const allPosts = allFiles.map((f) => {
  const c = fs.readFileSync(path.join(postsDir, f), 'utf-8');
  const { attributes, body } = parseFrontmatter(c);
  return {
    ...attributes as Record<string, unknown>,
    slug: f.replace(/\.md$/, ''),
    body,
    publishDate: new Date(attributes.publishDate as string),
  };
});

const matchingFile = allFiles.find((f) => f.replace(/\.md$/, '') === slug);
if (!matchingFile) {
  return Astro.redirect('/404');
}

const fileContent = fs.readFileSync(path.join(postsDir, matchingFile), 'utf-8');
const { attributes, body } = parseFrontmatter(fileContent);

// Draft posts redirect to 404
if ((attributes.draft as boolean)) {
  return Astro.redirect('/404');
}
const publishDate = new Date(attributes.publishDate as string);
const rawHtml = marked.parse(body);
const htmlContent = rawHtml.replace(/<h([23])>(.*?)<\/h\1>/gs, function(m, level, inner) {
  var plain = inner.replace(/<[^>]*>/g, '').replace(/&[^;]+;/g, '');
  var id = plain.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').replace(/-+/g, '-');
  return '<h' + level + ' id="' + id + '">' + inner + '</h' + level + '>';
});
const readingTime = getReadingTime(body);

const publishedPosts = allPosts.filter((p: any) => !p.draft);
const allCategories = [...new Set(publishedPosts.flatMap((p: any) => p.categories || []))] as string[];
const recentPosts = publishedPosts
  .filter((p: any) => p.slug !== slug)
  .sort((a: any, b: any) => b.publishDate.getTime() - a.publishDate.getTime())
  .slice(0, 5);
const trendingPosts = publishedPosts.filter((p: any) => p.tags && p.tags.includes('trending'));
const popularPosts = publishedPosts.filter((p: any) => p.tags && p.tags.includes('popular'));
const trending = await fetchTrendingNews();

const currentTags = (attributes.tags as string[]) || [];
const currentCategories = (attributes.categories as string[]) || [];
const relatedPosts = publishedPosts
  .filter((p: any) => p.slug !== slug)
  .map((p: any) => {
    const tagOverlap = (p.tags || []).filter((t: string) => currentTags.includes(t)).length;
    const catOverlap = (p.categories || []).filter((c: string) => currentCategories.includes(c)).length;
    const score = tagOverlap * 2 + catOverlap;
    return { ...p, score };
  })
  .filter((p: any) => p.score > 0)
  .sort((a: any, b: any) => b.score - a.score)
  .slice(0, 4);
---

<PostLayout
  title={attributes.title as string}
  description={attributes.excerpt as string}
  publishDate={publishDate}
  featuredImage={attributes.featuredImage as string}
  categories={attributes.categories as string[]}
  tags={attributes.tags as string[]}
  author={attributes.author as string}
  readingTime={readingTime}
  recentPosts={recentPosts}
  allCategories={allCategories}
  trendingPosts={trendingPosts}
  trending={trending}
  popularPosts={popularPosts}
  relatedPosts={relatedPosts}
  titleFontSize={attributes.titleFontSize as string}
  titleLineHeight={attributes.titleLineHeight as string}
>
  <div class="post-content" set:html={htmlContent} />
</PostLayout>

<style>
  .post-content {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    max-width: var(--content-width);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-6);
  }

  .post-content :global(h2) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }

  .post-content :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .post-content :global(strong) {
    font-weight: 600;
  }

  .post-content :global(em) {
    font-style: italic;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
