---
---

<!doctype html>
<html lang="en" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Admin — Aethel_AI</title>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js" is:inline></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: #F8FAFC;
      color: #0F172A;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      -webkit-font-smoothing: antialiased;
    }
    .login-card {
      background: #FFFFFF;
      border: 1px solid #E2E8F0;
      border-radius: 16px;
      padding: 48px 40px;
      width: 100%;
      max-width: 420px;
      text-align: center;
      box-shadow: 0 4px 24px rgba(15, 30, 54, 0.06);
    }
    .login-logo { margin-bottom: 32px; }
    .login-logo svg { display: inline-block; }
    .login-logo-text {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 24px;
      font-weight: 600;
      font-style: italic;
      color: #0F1E36;
      letter-spacing: -0.02em;
      display: block;
      margin-top: 8px;
    }
    .login-title {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 22px;
      font-weight: 500;
      margin-bottom: 8px;
    }
    .login-subtitle {
      color: #64748B;
      font-size: 15px;
      margin-bottom: 32px;
      line-height: 1.5;
    }
    .login-divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 24px 0;
      color: #94A3B8;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .login-divider::before, .login-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background-color: #E2E8F0;
    }
    .login-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      width: 100%;
      padding: 14px 20px;
      border: 1.5px solid #E2E8F0;
      border-radius: 10px;
      background: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 15px;
      font-weight: 500;
      color: #0F172A;
      cursor: pointer;
      transition: all 200ms;
      text-decoration: none;
      margin-bottom: 12px;
    }
    .login-btn:hover {
      border-color: #3B82F6;
      box-shadow: 0 2px 8px rgba(59, 130, 246, 0.1);
    }
    .login-btn svg { flex-shrink: 0; }
    .login-loader {
      display: none;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 24px;
    }
    .login-loader--active { display: flex; }
    .login-loader .spinner {
      width: 20px; height: 20px;
      border: 2px solid #E2E8F0;
      border-top-color: #3B82F6;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    @media (max-width: 480px) {
      .login-card { padding: 32px 24px; }
    }
  </style>
</head>
<body>
  <div class="login-card" id="login-card">
    <div class="login-logo">
      <svg width="48" height="48" viewBox="0 0 28 28" fill="none">
        <rect width="28" height="28" rx="6" fill="#3B82F6"/>
        <path d="M8 20V8h3.5l4.5 8.5V8H19v12h-3.5L11 11.5V20H8z" fill="white"/>
      </svg>
      <span class="login-logo-text">Aethel_AI</span>
    </div>
    <h1 class="login-title">Welcome back</h1>
    <p class="login-subtitle">Sign in to manage your blog content</p>
    <button class="login-btn" id="btn-google">
      <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Sign in with Google
    </button>
    <button class="login-btn" id="btn-github">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#24292F"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      Sign in with GitHub
    </button>
    <div class="login-divider">or</div>
    <button class="login-btn" id="btn-email">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      Sign in with Email
    </button>
    <div class="login-loader" id="login-loader">
      <div class="spinner"></div>
      <span>Signing in...</span>
    </div>
  </div>

  <script is:inline>
    (function() {
      if (window.netlifyIdentity) {
        window.netlifyIdentity.init();
        window.netlifyIdentity.on('init', function(user) {
          if (user) { window.location.href = '/admin/panel/'; }
        });
        window.netlifyIdentity.on('login', function() {
          window.location.href = '/admin/panel/';
        });
      }

      function doLogin(provider) {
        var loader = document.getElementById('login-loader');
        loader.classList.add('login-loader--active');
        if (window.netlifyIdentity) {
          if (provider === 'email') {
            window.netlifyIdentity.open('login');
          } else {
            window.netlifyIdentity.externalLogin(provider);
          }
        }
      }

      document.getElementById('btn-google').addEventListener('click', function() { doLogin('google'); });
      document.getElementById('btn-github').addEventListener('click', function() { doLogin('github'); });
      document.getElementById('btn-email').addEventListener('click', function() { doLogin('email'); });

      if (window.netlifyIdentity && window.netlifyIdentity.currentUser()) {
        window.location.href = '/admin/panel/';
      }
    })();
  </script>
</body>
</html>
