---
import AdminLayout from '../components/admin/AdminLayout.astro';
---

<AdminLayout>
  <div id="app">
    <div class="login-container">
      <div class="login-card">
        <div class="login-logo">
          <svg width="48" height="48" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="6" fill="#3B82F6"/>
            <path d="M8 22 L11 7 Q11.3 5.5 13 5.5 Q14.7 5.5 15 7 L18 22 L16 22 L15 16.5 H10 L9 22 Z M10.5 14.5 H14.5 L12.5 9.5 Z" fill="white"/>
          </svg>
        </div>
        <h1 class="login-title">Admin Login</h1>
        <p class="login-subtitle">Enter your GitHub token to manage the blog</p>

        <div class="login-error" id="login-error"></div>

        <form class="login-form" id="login-form" onsubmit="return handleLogin(event)">
          <div class="login-field">
            <label for="pat">GitHub Personal Access Token</label>
            <input type="password" id="pat" placeholder="ghp_..." autocomplete="off" required />
            <div class="login-hint">
              Needs <strong>repo</strong> scope.
              <a href="https://github.com/settings/tokens" target="_blank" style="color:#3B82F6;text-decoration:none;font-weight:500">Create one →</a>
            </div>
          </div>
          <button type="submit" class="login-submit" id="login-btn">Verify & Sign In</button>
        </form>

        <div class="login-loader" id="login-loader">
          <div class="spinner"></div>
          <span>Verifying token...</span>
        </div>

        <div class="login-divider">or</div>

        <button class="login-gh-btn" onclick="window.location.href='/'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Back to Site
        </button>
      </div>
    </div>
  </div>
<script is:inline>
  (function() {
    // Theme
    var saved = localStorage.getItem('theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.setAttribute('data-theme', saved || (prefersDark ? 'dark' : 'light'));

    // Check if already authenticated
    var existingPat = localStorage.getItem('aa_github_pat');
    if (existingPat) {
      // Quick validation
      fetch('https://api.github.com/user', {
        headers: { 'Authorization': 'Bearer ' + existingPat, 'Accept': 'application/vnd.github.v3+json' }
      }).then(function(r) {
        if (r.ok) window.location.href = '/admin/panel/';
      }).catch(function() {});
    }

    function showError(msg) {
      var el = document.getElementById('login-error');
      el.textContent = msg;
      el.style.display = 'block';
    }

    function clearError() {
      var el = document.getElementById('login-error');
      el.style.display = 'none';
    }

    function setLoading(loading) {
      var loader = document.getElementById('login-loader');
      var btn = document.getElementById('login-btn');
      loader.style.display = loading ? 'flex' : 'none';
      btn.disabled = loading;
    }

    async function handleLogin(e) {
      e.preventDefault();
      clearError();

      var pat = document.getElementById('pat').value.trim();
      if (!pat) { showError('Please enter your GitHub token'); return false; }

      setLoading(true);

      try {
        // Validate by fetching user + repo
        var userRes = await fetch('https://api.github.com/user', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' }
        });
        if (!userRes.ok) {
          var errData;
          try { errData = await userRes.json(); } catch(e) {}
          showError(errData && errData.message ? errData.message : 'Invalid token. Please check and try again.');
          setLoading(false);
          return false;
        }

        var user = await userRes.json();

        // Check repo access
        var repoRes = await fetch('https://api.github.com/repos/greatokon98/aethel-ai', {
          headers: { 'Authorization': 'Bearer ' + pat, 'Accept': 'application/vnd.github.v3+json' }
        });
        if (!repoRes.ok) {
          showError('Token valid but does not have access to greatokon98/aethel-ai. Make sure it has repo scope.');
          setLoading(false);
          return false;
        }

        // Store token
        localStorage.setItem('aa_github_pat', pat);
        localStorage.setItem('aa_user', JSON.stringify({ login: user.login, name: user.name || user.login, avatar: user.avatar_url }));

        window.location.href = '/admin/panel/';
      } catch(err) {
        showError('Connection error: ' + err.message);
        setLoading(false);
      }

      return false;
    }

    window.handleLogin = handleLogin;
  })();
</script>

<style is:global>
  .login-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 20px;
    position: relative;
    z-index: 1;
  }
  .login-card {
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 48px 40px;
    width: 100%;
    max-width: 420px;
    text-align: center;
    box-shadow: 0 4px 24px rgba(15, 30, 54, 0.06);
  }
  [data-theme="dark"] .login-card {
    background: #1E293B;
    border-color: #334155;
  }
  .login-logo { margin-bottom: 24px; }
  .login-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 4px;
  }
  .login-subtitle {
    color: #64748B;
    font-size: 15px;
    margin-bottom: 28px;
    line-height: 1.5;
  }
  [data-theme="dark"] .login-subtitle { color: #94A3B8; }
  .login-form { text-align: left; }
  .login-field { margin-bottom: 20px; }
  .login-field label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #475569;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  [data-theme="dark"] .login-field label { color: #94A3B8; }
  .login-field input {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid #E2E8F0;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    color: #0F172A;
    background: #F8FAFC;
    transition: border-color 200ms, box-shadow 200ms;
    outline: none;
  }
  .login-field input:focus {
    border-color: #3B82F6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
    background: #FFFFFF;
  }
  [data-theme="dark"] .login-field input {
    background: #0F172A;
    border-color: #334155;
    color: #F1F5F9;
  }
  [data-theme="dark"] .login-field input:focus {
    border-color: #3B82F6;
    background: #0F172A;
  }
  .login-hint {
    font-size: 12px;
    color: #94A3B8;
    margin-top: 6px;
    line-height: 1.5;
  }
  .login-submit {
    width: 100%;
    padding: 14px;
    background: #3B82F6;
    color: white;
    border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 200ms, transform 100ms;
    margin-top: 4px;
  }
  .login-submit:hover { background: #2563EB; }
  .login-submit:disabled {
    background: #93C5FD;
    cursor: not-allowed;
  }
  .login-error {
    display: none;
    background: #FEF2F2;
    border: 1px solid #FCA5A5;
    color: #B91C1C;
    font-size: 14px;
    padding: 12px 16px;
    border-radius: 10px;
    margin-bottom: 16px;
    text-align: center;
  }
  .login-loader {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
    color: #64748B;
    font-size: 14px;
  }
  .login-loader .spinner {
    width: 18px; height: 18px;
    border: 2px solid #E2E8F0;
    border-top-color: #3B82F6;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    flex-shrink: 0;
  }
  .login-divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 20px 0;
    color: #94A3B8;
    font-size: 13px;
  }
  .login-divider::before, .login-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: #E2E8F0;
  }
  .login-gh-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 20px;
    border: 1.5px solid #E2E8F0;
    border-radius: 10px;
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #64748B;
    cursor: pointer;
    transition: all 200ms;
  }
  .login-gh-btn:hover {
    border-color: #3B82F6;
    color: #3B82F6;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</AdminLayout>
