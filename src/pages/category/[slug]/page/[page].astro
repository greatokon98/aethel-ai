---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/PostCard.astro';
import Sidebar from '../../../../components/Sidebar.astro';
import Pagination from '../../../../components/Pagination.astro';
import { loadAllPosts, paginatePosts } from '../../../../lib/posts';
import { getConfig } from '../../../../lib/site-config';

export function getStaticPaths() {
  const allPosts = loadAllPosts();
  const config = getConfig();
  const perPage = config.content.postsPerPage || 12;

  const catsToSlugs = new Map<string, string>();
  allPosts.forEach((p) => {
    p.categories.forEach((c) => {
      const slug = c.toLowerCase().replace(/\s+/g, '-');
      if (!catsToSlugs.has(slug)) catsToSlugs.set(slug, c);
    });
  });

  const paths: { params: { slug: string; page: string }; props: { slug: string } }[] = [];
  catsToSlugs.forEach((catName, catSlug) => {
    const filtered = allPosts.filter((p) =>
      p.categories.some((c) => c.toLowerCase().replace(/\s+/g, '-') === catSlug)
    );
    const totalPages = Math.max(1, Math.ceil(filtered.length / perPage));
    for (let p = 2; p <= totalPages; p++) {
      paths.push({ params: { slug: catSlug, page: String(p) }, props: { slug: catSlug } });
    }
  });
  return paths;
}

const { slug } = Astro.params;
const pageNum = Math.max(2, parseInt(Astro.params.page || '2', 10) || 2);

const allPosts = loadAllPosts();
const config = getConfig();
const perPage = config.content.postsPerPage || 12;

const categoryName = slug!.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
const filtered = allPosts.filter((p) =>
  p.categories.some((c) => c.toLowerCase().replace(/\s+/g, '-') === slug)
);
const page = paginatePosts(filtered, pageNum, perPage);

if (page.currentPage !== pageNum || page.currentPage <= 1) {
  return Astro.redirect(`/category/${slug}`);
}

const allCategories = [...new Set(allPosts.flatMap((p) => p.categories))];
const trendingPosts = allPosts.filter((p) => p.tags && p.tags.includes('trending'));
const popularPosts = allPosts.filter((p) => p.tags && p.tags.includes('popular'));
---

<BaseLayout title={`${categoryName} — Page ${page.currentPage}`} description={`Articles about ${categoryName} — Page ${page.currentPage}`}>
  <section class="section category-page">
    <div class="container">
      <div class="category-page__layout">
        <div class="category-page__main">
          <h1 class="category-page__title">{categoryName}</h1>
          <p class="category-page__count">{filtered.length} post{filtered.length !== 1 ? 's' : ''} — Page {page.currentPage}</p>
          {page.posts.length > 0 ? (
            <div class="category-page__grid">
              {page.posts.map((post, i) => (
                <div class:fade-in={{ true: true, [`fade-in--delay-${Math.min(i + 1, 4)}`]: true }}>
                  <PostCard
                    title={post.title}
                    excerpt={post.excerpt}
                    publishDate={post.publishDate}
                    slug={post.slug}
                    featuredImage={post.featuredImage}
                    categories={post.categories}
                    author={post.author}
                    readingTime={post.readingTime}
                    featured={false}
                    titleFontSize={post.titleFontSize}
                    titleLineHeight={post.titleLineHeight}
                  />
                </div>
              ))}
            </div>
          ) : (
            <p class="category-page__empty">No posts found in this category.</p>
          )}
          <Pagination
            currentPage={page.currentPage}
            totalPages={page.totalPages}
            hasPrev={page.hasPrev}
            hasNext={page.hasNext}
            prevUrl={page.hasPrev ? `/category/${slug}${page.currentPage === 2 ? '' : `/page/${page.currentPage - 1}`}` : null}
            nextUrl={page.hasNext ? `/category/${slug}/page/${page.currentPage + 1}` : null}
            basePath={`/category/${slug}`}
          />
        </div>
        <div class="category-page__sidebar">
          <Sidebar
            categories={allCategories}
            recentPosts={allPosts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: p.publishDate,
            }))}
            trendingPosts={trendingPosts}
            popularPosts={popularPosts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: p.publishDate,
            }))}
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-page__layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width);
    gap: var(--space-12);
    align-items: start;
    padding-top: var(--space-16);
  }

  .category-page__sidebar {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  .category-page__title {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .category-page__count {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .category-page__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .category-page__empty {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
  }

  @media (max-width: 1024px) {
    .category-page__layout {
      grid-template-columns: 1fr 280px;
      gap: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .category-page__layout {
      grid-template-columns: 1fr;
    }

    .category-page__sidebar {
      position: static;
    }

    .category-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
