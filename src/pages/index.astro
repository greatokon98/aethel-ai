---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { getConfig } from '../lib/site-config';
import { fetchTrendingNews } from '../lib/trending';
import fs from 'node:fs';
import path from 'node:path';
import parseFrontmatter from 'front-matter';

const postsDir = path.resolve('src/content/posts');
const files = fs.readdirSync(postsDir).filter((f) => f.endsWith('.md'));

function getSlug(file: string) {
  return file.replace(/\.md$/, '');
}

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const posts = files
  .map((file) => {
    const content = fs.readFileSync(path.join(postsDir, file), 'utf-8');
    const { attributes, body } = parseFrontmatter(content);
    return {
      title: attributes.title as string || '',
      excerpt: attributes.excerpt as string || '',
      publishDate: new Date(attributes.publishDate as string || Date.now()),
      featuredImage: attributes.featuredImage as string || '',
      categories: (attributes.categories as string[]) || [],
      tags: (attributes.tags as string[]) || [],
      author: (attributes.author as string) || 'Aethel',
      featured: (attributes.featured as boolean) || false,
      slug: getSlug(file),
      readingTime: getReadingTime(body),
    };
  })
  .sort((a, b) => {
    if (a.featured !== b.featured) return a.featured ? -1 : 1;
    return b.publishDate.getTime() - a.publishDate.getTime();
  });

const allCategories = [...new Set(posts.flatMap((p) => p.categories))];
const trendingPosts = posts.filter((p) => p.tags && p.tags.includes('trending'));
const trending = await fetchTrendingNews();
---

<BaseLayout title="Home" description="Smart tools for everyday life — no jargon, just results.">
  <Hero posts={posts} />

  <section class="section blog-grid">
    <div class="container">
      <div class="blog-grid__layout">
        <div class="blog-grid__main">
          <div class="mobile-search-bar">
            <form class="mobile-search-form" action="/search" method="get">
              <svg class="mobile-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
              <input type="text" name="q" placeholder="Search articles..." class="mobile-search-input" />
            </form>
            <div class="mobile-category-wrapper">
              <button type="button" class="mobile-category-trigger" data-category-toggle>
                <span data-category-label>All Categories</span>
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <ul class="mobile-category-menu" data-category-menu>
                <li><a href="/">All Categories</a></li>
                {allCategories.map(cat => {
                  const catSlug = cat.toLowerCase().replace(/\s+/g, '-');
                  return <li><a href={`/category/${catSlug}`}>{cat}</a></li>;
                })}
              </ul>
            </div>
          </div>
          <h2 class="section-title fade-in">Latest Posts</h2>
          <div class="blog-grid__posts">
            {posts.filter(p => !p.featured).map((post, i) => (
              <div
                class:fade-in={{ true: true, [`fade-in--delay-${Math.min(i + 1, 4)}`]: true }}
              >
                <PostCard
                  title={post.title}
                  excerpt={post.excerpt}
                  publishDate={post.publishDate}
                  slug={post.slug}
                  featuredImage={post.featuredImage}
                  categories={post.categories}
                  author={post.author}
                  readingTime={post.readingTime}
                  featured={false}
                />
              </div>
            ))}
          </div>
        </div>
        <div class="blog-grid__sidebar">
          <Sidebar
            categories={allCategories}
            recentPosts={posts.map((p) => ({
              title: p.title,
              slug: p.slug,
              publishDate: p.publishDate,
            }))}
            trendingPosts={trendingPosts}
            trending={trending}
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section featured-section">
    <div class="container">
      <h2 class="section-title fade-in">Featured Stories</h2>
      <div class="featured-grid">
        {posts.filter(p => p.featured).map((post, i) => (
          <div class:fade-in={{ true: true, [`fade-in--delay-${Math.min(i + 1, 4)}`]: true }}>
            <PostCard
              title={post.title}
              excerpt={post.excerpt}
              publishDate={post.publishDate}
              slug={post.slug}
              featuredImage={post.featuredImage}
              categories={post.categories}
              author={post.author}
              readingTime={post.readingTime}
              featured={false}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .featured-section {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
  }

  .featured-grid {
    display: flex;
    gap: var(--space-6);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: var(--space-4);
    scrollbar-width: thin;
  }

  .featured-grid > * {
    flex: 0 0 360px;
    scroll-snap-align: start;
    display: flex;
    height: 100%;
  }

  .mobile-search-bar {
    display: none;
  }

  @media (max-width: 768px) {
    .featured-grid { gap: var(--space-4); }
    .featured-grid > * { flex: 0 0 300px; }

    .mobile-search-bar {
      display: flex;
      gap: var(--space-3);
      margin-bottom: var(--space-6);
      align-items: stretch;
    }

    .mobile-search-form {
      position: relative;
      flex: 1;
    }

    .mobile-search-icon {
      position: absolute;
      left: var(--space-3);
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-text-muted);
      pointer-events: none;
    }

    .mobile-search-input {
      width: 100%;
      height: 100%;
      padding: var(--space-3) var(--space-3) var(--space-3) var(--space-10);
      font-family: var(--font-body);
      font-size: var(--text-base);
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-md);
      background-color: var(--color-bg);
      color: var(--color-text);
      outline: none;
      transition: border-color var(--transition);
    }

    .mobile-search-input:focus {
      border-color: var(--color-accent);
    }

    .mobile-search-input::placeholder {
      color: var(--color-text-muted);
    }

    .mobile-category-wrapper {
      position: relative;
      min-width: 160px;
    }

    .mobile-category-trigger {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-2);
      padding: var(--space-3);
      font-family: var(--font-body);
      font-size: var(--text-base);
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-md);
      background-color: var(--color-bg);
      color: var(--color-text);
      cursor: pointer;
      transition: border-color var(--transition);
      white-space: nowrap;
    }

    .mobile-category-trigger:hover,
    .mobile-category-trigger:focus {
      border-color: var(--color-accent);
      outline: none;
    }

    .mobile-category-trigger svg {
      flex-shrink: 0;
      color: var(--color-text-muted);
      transition: transform var(--transition);
    }

    .mobile-category-trigger[aria-expanded="true"] svg {
      transform: rotate(180deg);
    }

    .mobile-category-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 50;
      display: none;
      margin-top: 4px;
      list-style: none;
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-lg);
      max-height: 40vh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    .mobile-category-menu--open {
      display: block;
    }

    .mobile-category-menu li {
      border-bottom: 1px solid var(--color-border);
    }

    .mobile-category-menu li:last-child {
      border-bottom: none;
    }

    .mobile-category-menu a {
      display: block;
      padding: var(--space-3);
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      text-decoration: none;
      transition: background-color var(--transition);
    }

    .mobile-category-menu a:hover {
      background-color: var(--color-surface-hover);
      color: var(--color-accent);
    }
  }

  .blog-grid__layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width);
    gap: var(--space-12);
    align-items: start;
  }

  .blog-grid__sidebar {
    position: sticky;
    top: 88px;
    align-self: start;
  }

  .blog-grid__posts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    align-content: start;
  }

  @media (max-width: 1024px) {
    .blog-grid__layout {
      grid-template-columns: 1fr 280px;
      gap: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .blog-grid__layout {
      grid-template-columns: 1fr;
    }

    .blog-grid__sidebar {
      position: static;
    }

    .blog-grid__posts {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('[data-category-toggle]');
    const menu = document.querySelector('[data-category-menu]');
    const label = document.querySelector('[data-category-label]');

    if (!toggle || !menu) return;

    function close() {
      menu.classList.remove('mobile-category-menu--open');
      toggle.setAttribute('aria-expanded', 'false');
    }

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = menu.classList.toggle('mobile-category-menu--open');
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (label) label.textContent = link.textContent;
        close();
      });
    });

    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target) && !menu.contains(e.target)) {
        close();
      }
    });
  });
</script>
