---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

export interface Props {
  title: string;
  description?: string;
  publishDate: Date;
  featuredImage?: string;
  categories?: string[];
  tags?: string[];
  author?: string;
  readingTime?: number;
  recentPosts?: Array<{
    title: string;
    slug: string;
    publishDate: Date;
  }>;
  trendingPosts?: Array<{
    title: string;
    slug: string;
    publishDate: Date;
  }>;
  allCategories?: string[];
  trending?: Array<{
    title: string;
    link: string;
    source: string;
    pubDate: string;
    description: string;
  }>;
  popularPosts?: Array<{
    title: string;
    slug: string;
    publishDate: Date;
  }>;
  relatedPosts?: Array<{
    title: string;
    slug: string;
    excerpt: string;
    publishDate: Date;
    featuredImage?: string;
    categories?: string[];
    author?: string;
    readingTime?: number;
  }>;
  titleFontSize?: string;
  titleLineHeight?: string;
}

const {
  title,
  description,
  publishDate,
  featuredImage,
  categories,
  tags,
  author,
  readingTime,
  recentPosts = [],
  trendingPosts = [],
  allCategories = [],
  trending = [],
  popularPosts = [],
  relatedPosts = [],
  titleFontSize = '48',
  titleLineHeight = '1.2',
} = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={featuredImage}>
  <div class="reading-progress" id="reading-progress"></div>
  <article class="post-page">
    <div class="container">
      <div class="post-page__layout">
        <div class="post-page__main">
          <header class="post-page__header">
            {categories && categories.length > 0 && (
              <div class="post-page__categories">
                {categories.map((cat) => (
                  <span class="post-page__category">{cat}</span>
                ))}
              </div>
            )}
            <h1 class="post-page__title" style={`font-size: ${titleFontSize}px; line-height: ${titleLineHeight}`}>{title}</h1>
            <div class="post-page__meta">
              <time datetime={publishDate.toISOString()}>{formattedDate}</time>
              {readingTime && <span class="post-page__reading">{readingTime} min read</span>}
              {author && <span>by {author}</span>}
            </div>
          </header>

          {featuredImage && (
            <div class="post-page__image-wrapper">
              <img src={featuredImage} alt={title} class="post-page__image" loading="lazy" decoding="async" />
            </div>
          )}

          <div class="post-page__content">
            <nav class="post-page__toc" id="post-toc">
              <div class="post-page__toc-header">
                <span class="post-page__toc-title">On this page</span>
                <button class="post-page__toc-toggle" id="post-toc-toggle" aria-label="Toggle table of contents">▾</button>
              </div>
              <ul class="post-page__toc-list" id="post-toc-list"></ul>
            </nav>
            <slot />
          </div>

          {tags && tags.length > 0 && (
            <footer class="post-page__footer">
              <div class="post-page__tags">
                <span class="post-page__tags-label">Tags</span>
                {tags.map((tag) => (
                  <span class="post-page__tag">{tag}</span>
                ))}
              </div>
            </footer>
          )}

          <RelatedPosts posts={relatedPosts || []} />
        </div>
        <div class="post-page__sidebar">
          <Sidebar categories={allCategories} recentPosts={recentPosts} trendingPosts={trendingPosts} trending={trending} popularPosts={popularPosts} />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-page {
    padding: var(--space-16) 0 var(--space-16);
  }

  .post-page__layout {
    display: grid;
    grid-template-columns: 1fr var(--sidebar-width);
    gap: var(--space-12);
  }

  .post-page__main {
    min-width: 0;
  }

  .post-page__header {
    margin-bottom: var(--space-8);
  }

  .post-page__categories {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .post-page__category {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .post-page__title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .post-page__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
  }

  .post-page__reading::before {
    content: '·';
    margin-right: var(--space-3);
  }

  .post-page__image-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--space-10);
  }

  .post-page__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .post-page__content {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: var(--leading-relaxed);
    max-width: var(--content-width);
    font-weight: 300;
  }

  .post-page__content p {
    margin-bottom: var(--space-6);
  }

  .post-page__content h2 {
    font-family: var(--font-heading);
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }

  .post-page__content h3 {
    font-family: var(--font-heading);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    font-weight: 500;
  }

  .post-page__content ul,
  .post-page__content ol {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-page__content li {
    margin-bottom: var(--space-2);
  }

  .post-page__content blockquote {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    font-style: italic;
    color: var(--color-text-secondary);
    position: relative;
  }

  .post-page__content blockquote::before {
    content: '\201C';
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    color: var(--color-accent);
    position: absolute;
    top: -0.5rem;
    left: var(--space-3);
    opacity: 0.3;
    line-height: 1;
  }

  .post-page__content strong {
    font-weight: 500;
  }

  .post-page__content em {
    font-style: italic;
  }

  .post-page__content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-light);
    text-underline-offset: 2px;
  }

  .post-page__content a:hover {
    text-decoration-color: var(--color-accent);
  }

  .post-page__content img {
    border-radius: var(--radius-md);
    margin: var(--space-8) 0;
  }

  .post-page__content code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .post-page__content pre {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .post-page__content pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: var(--text-sm);
  }

  .post-page__footer {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .post-page__tags {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .post-page__tags-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-right: var(--space-2);
  }

  .post-page__tag {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    padding: var(--space-1) var(--space-3);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
  }

  @media (max-width: 1024px) {
    .post-page__layout {
      grid-template-columns: 1fr 280px;
      gap: var(--space-8);
    }

    .post-page__title {
      font-size: var(--text-4xl);
    }
  }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    background: var(--color-accent);
    width: 0%;
    z-index: 9999;
    transition: width 0.1s linear;
  }

  .post-page__toc {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-6);
    margin-bottom: var(--space-8);
  }

  .post-page__toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .post-page__toc-title {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .post-page__toc-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-1);
    display: none;
    transition: transform 0.2s;
  }

  .post-page__toc.is-collapsed .post-page__toc-toggle {
    transform: rotate(-90deg);
  }

  .post-page__toc-list {
    list-style: none;
    margin: var(--space-3) 0 0 0;
    padding: 0;
    font-size: var(--text-sm);
  }

  .post-page__toc-list li {
    margin-bottom: var(--space-1);
  }

  .post-page__toc-list a {
    color: var(--color-text-secondary);
    text-decoration: none;
    display: block;
    padding: var(--space-1) 0;
    border-left: 2px solid transparent;
    padding-left: var(--space-3);
    transition: color 0.15s, border-color 0.15s;
  }

  .post-page__toc-list a:hover,
  .post-page__toc-list a:focus {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }

  .post-page__toc-list a.is-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  .post-page__toc-list .toc-h3 {
    padding-left: var(--space-6);
    font-size: 0.925em;
  }

  @media (max-width: 768px) {
    .post-page__toc-toggle {
      display: block;
    }

    .post-page__toc.is-collapsed .post-page__toc-list {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .post-page__layout {
      grid-template-columns: 1fr;
    }

    .post-page__title {
      font-size: var(--text-3xl);
    }

    .post-page__image-wrapper {
      margin: 0 calc(-1 * var(--space-4)) var(--space-8);
      border-radius: 0;
    }

    .post-page__content {
      font-size: var(--text-base);
    }

    .post-page__meta {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  (function() {
    var toc = document.getElementById('post-toc');
    var list = document.getElementById('post-toc-list');
    var progress = document.getElementById('reading-progress');
    var toggle = document.getElementById('post-toc-toggle');

    if (toc && list) {
      var headings = document.querySelectorAll('.post-page__content h2, .post-page__content h3');
      if (headings.length === 0) {
        toc.style.display = 'none';
      } else {
        headings.forEach(function(h) {
          if (!h.id) return;
          var li = document.createElement('li');
          var a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = h.textContent;
          if (h.tagName === 'H3') a.className = 'toc-h3';
          li.appendChild(a);
          list.appendChild(li);
        });

        if (toggle) {
          toggle.addEventListener('click', function() {
            toc.classList.toggle('is-collapsed');
          });
        }

        var links = list.querySelectorAll('a');
        function onScroll() {
          var scrollY = window.scrollY;
          var activeIdx = -1;
          headings.forEach(function(h, i) {
            if (h.offsetTop - 120 <= scrollY) activeIdx = i;
          });
          links.forEach(function(a, i) {
            a.classList.toggle('is-active', i === activeIdx);
          });
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    }

    if (progress) {
      function onProgress() {
        var scrollY = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight > 0) {
          progress.style.width = Math.min(100, (scrollY / docHeight) * 100) + '%';
        }
      }
      window.addEventListener('scroll', onProgress, { passive: true });
      onProgress();
    }
  })();
</script>
