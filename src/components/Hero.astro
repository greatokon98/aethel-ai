---
export interface Props {
  posts: Array<{
    title: string;
    excerpt: string;
    slug: string;
    publishDate: Date;
    featuredImage?: string;
    categories?: string[];
    readingTime?: number;
  }>;
}

const { posts } = Astro.props;
const featured = posts.filter((p) => (p as any).featured).length ? posts.filter((p) => (p as any).featured) : posts.slice(0, 3);
---

<section class="hero" id="hero-section">
  <div class="hero__slider" id="hero-slider">
    <div class="hero__canvas" id="hero-canvas"></div>
    {featured.map((post, index) => (
      <a
        href={`/posts/${post.slug}`}
        class="hero__slide"
        class:list={{ 'hero__slide--active': index === 0 }}
        data-slide={index}
      >
        <div class="hero__slide-bg">
          {post.featuredImage ? (
            <img src={post.featuredImage} alt={post.title} class="hero__slide-image" />
          ) : (
            <div class="hero__slide-placeholder"></div>
          )}
          <div class="hero__slide-overlay"></div>
        </div>
        <div class="hero__slide-content">
          {post.categories && post.categories.length > 0 && (
            <span class="hero__slide-category">{post.categories[0]}</span>
          )}
          <h2 class="hero__slide-title">{post.title}</h2>
          <p class="hero__slide-excerpt">{post.excerpt}</p>
          <div class="hero__slide-meta">
            <span class="hero__slide-date">
              {post.publishDate.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              })}
            </span>
            {post.readingTime && (
              <span class="hero__slide-reading">{post.readingTime} min read</span>
            )}
            <span class="hero__slide-cta">
              Read article
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      </a>
    ))}
    <div class="hero__progress" id="hero-progress">
      <div class="hero__progress-bar" id="hero-progress-bar"></div>
    </div>
  </div>
</section>

<script>
  (function() {
    const slider = document.getElementById('hero-slider');
    if (!slider) return;

    const slides = slider.querySelectorAll('.hero__slide');
    const progressBar = document.getElementById('hero-progress-bar');
    let current = 0;
    let animFrame = null;
    let startTime = null;
    const DURATION = 8000;

    function goToSlide(index) {
      slides.forEach((s, i) => {
        s.classList.toggle('hero__slide--active', i === index);
      });
      current = index;
      startTime = null;
      if (progressBar) progressBar.style.width = '0%';
    }

    function tick(time) {
      if (!startTime) startTime = time;
      const elapsed = time - startTime;
      const pct = Math.min((elapsed / DURATION) * 100, 100);
      if (progressBar) progressBar.style.width = pct + '%';
      if (elapsed >= DURATION) {
        goToSlide((current + 1) % slides.length);
      }
      animFrame = requestAnimationFrame(tick);
    }

    animFrame = requestAnimationFrame(tick);

    slider.addEventListener('mouseenter', () => {
      if (animFrame) cancelAnimationFrame(animFrame);
      animFrame = null;
      if (progressBar) progressBar.style.width = '0%';
    });

    slider.addEventListener('mouseleave', () => {
      startTime = null;
      animFrame = requestAnimationFrame(tick);
    });

    slides.forEach((slide) => {
      slide.addEventListener('click', (e) => {
        if (!slide.classList.contains('hero__slide--active')) {
          e.preventDefault();
          goToSlide(parseInt(slide.dataset.slide));
        }
      });
    });

    // Starfield
    (function initStars() {
      const canvas = document.getElementById('hero-canvas');
      if (!canvas) return;
      const cvs = document.createElement('canvas');
      const ctx = cvs.getContext('2d');
      if (!ctx) return;
      const hero = document.getElementById('hero-section');
      if (!hero) return;
      let appended = false;

      function getStarColor() {
        const theme = document.documentElement.getAttribute('data-theme');
        return theme === 'dark' ? '255,255,255' : '15,30,54';
      }

      const resize = () => {
        const rect = hero.getBoundingClientRect();
        cvs.width = rect.width;
        cvs.height = rect.height;
        cvs.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0.6;';
        if (!appended) {
          canvas.appendChild(cvs);
          appended = true;
        }
      };

      const stars = [];
      const COUNT = 70;

      function initStarsArr(w, h) {
        stars.length = 0;
        for (let i = 0; i < COUNT; i++) {
          stars.push({
            x: Math.random() * w,
            y: Math.random() * h,
            r: Math.random() * 1.5 + 0.5,
            speed: Math.random() * 0.12 + 0.02,
            drift: Math.random() * 0.06 - 0.03,
            phase: Math.random() * Math.PI * 2,
          });
        }
      }

      function draw() {
        const w = cvs.width, h = cvs.height;
        if (w === 0 || h === 0) { requestAnimationFrame(draw); return; }
        ctx.clearRect(0, 0, w, h);
        const t = Date.now() / 1000;
        const starColor = getStarColor();

        for (const s of stars) {
          s.y -= s.speed;
          s.x += s.drift;
          if (s.y < 0) { s.y = h; s.x = Math.random() * w; }
          if (s.x < 0) s.x = w;
          if (s.x > w) s.x = 0;

          const twinkle = 0.4 + 0.6 * (0.5 + 0.5 * Math.sin(t * 1.2 + s.phase));
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${starColor}, ${twinkle * 0.5})`;
          ctx.fill();
        }

        requestAnimationFrame(draw);
      }

      resize();
      initStarsArr(cvs.width, cvs.height);
      draw();

      const onResize = () => {
        resize();
        initStarsArr(cvs.width, cvs.height);
      };
      window.addEventListener('resize', onResize);

      // Watch for theme changes
      const themeObserver = new MutationObserver(() => {
        // Colors update automatically on next frame via getStarColor()
      });
      themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    })();
  })();
</script>

<style>
  .hero {
    padding: var(--space-8) 0 0;
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    position: relative;
  }

  .hero__canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__slider {
    position: relative;
    overflow: hidden;
    min-height: 520px;
    margin: 0 var(--space-6);
    border-radius: var(--radius-xl);
    z-index: 1;
  }

  .hero__slide {
    position: absolute;
    inset: 0;
    text-decoration: none;
    color: white;
    opacity: 0;
    transition: opacity 700ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    display: flex;
    z-index: 1;
  }

  .hero__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  .hero__slide-bg {
    position: absolute;
    inset: 0;
  }

  .hero__slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__slide-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-lighter));
  }

  .hero__slide-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 30, 54, 0.9) 0%, rgba(15, 30, 54, 0.4) 50%, transparent 100%);
  }

  .hero__slide-content {
    position: relative;
    z-index: 2;
    align-self: flex-end;
    padding: var(--space-12);
    max-width: 680px;
  }

  .hero__slide-category {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background-color: var(--color-accent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-4);
    font-weight: 600;
  }

  .hero__slide-title {
    font-family: var(--font-heading);
    font-size: var(--text-5xl);
    color: white;
    margin-bottom: var(--space-3);
    font-weight: 500;
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
  }

  .hero__slide-excerpt {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: var(--space-6);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 300;
  }

  .hero__slide-meta {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }

  .hero__slide-date,
  .hero__slide-reading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
  }

  .hero__slide-reading::before {
    content: '\00B7';
    margin-right: var(--space-5);
  }

  .hero__slide-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: white;
    padding-bottom: 2px;
    border-bottom: 2px solid var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: auto;
    z-index: 3;
  }

  .hero__progress {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 5;
    height: 2px;
    background-color: rgba(255, 255, 255, 0.12);
    overflow: hidden;
  }

  .hero__progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-accent), #60A5FA);
    box-shadow: 0 0 8px var(--color-accent), 0 0 20px rgba(59, 130, 246, 0.25);
    border-radius: 0 1px 1px 0;
    transition: width 0.1s linear;
  }

  @media (max-width: 1024px) {
    .hero__slider { min-height: 440px; }
    .hero__slide-title { font-size: var(--text-4xl); }
    .hero__slide-content { padding: var(--space-8); }
  }

  @media (max-width: 768px) {
    .hero__slider {
      min-height: 320px;
      margin: 0 var(--space-4);
      border-radius: var(--radius-lg);
    }
    .hero__slide-content { padding: var(--space-5); }
    .hero__slide-title { font-size: var(--text-2xl); }
    .hero__slide-excerpt { display: none; }
    .hero__slide-meta { gap: var(--space-2); font-size: var(--text-xs); }
    .hero__slide-reading::before { margin-right: var(--space-2); }
    .hero__slide-cta { display: none; }
  }
</style>
