---
export interface Props {
  title: string;
  excerpt: string;
  publishDate: Date;
  slug: string;
  featuredImage?: string;
  categories?: string[];
  author?: string;
  readingTime?: number;
  featured?: boolean;
}

const { title, excerpt, publishDate, slug, featuredImage, categories, author, readingTime, featured } = Astro.props;
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const cardClass = featured ? 'post-card post-card--featured' : 'post-card';
---

<article class={cardClass}>
  <a href={`/posts/${slug}`} class="post-card__link">
    <div class="post-card__image-wrapper">
      {featuredImage ? (
        <img src={featuredImage} alt={title} class="post-card__image" loading="lazy" />
      ) : (
        <div class="post-card__image-placeholder"></div>
      )}
      {featured && <span class="post-card__featured-badge">Featured</span>}
    </div>
    <div class="post-card__content">
      {categories && categories.length > 0 && (
        <div class="post-card__categories">
          {categories.map((cat) => (
            <span class="post-card__category">{cat}</span>
          ))}
        </div>
      )}
      <h3 class="post-card__title">{title}</h3>
      <p class="post-card__excerpt">{excerpt}</p>
      <div class="post-card__meta">
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
        {readingTime && <span class="post-card__reading">{readingTime} min read</span>}
        {author && <span class="post-card__author">by {author}</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
    border: 1px solid var(--color-border);
  }

  .post-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .post-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .post-card--featured .post-card__link {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .post-card--featured .post-card__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .post-card--featured .post-card__title {
    font-size: var(--text-3xl);
  }

  .post-card--featured .post-card__excerpt {
    font-size: var(--text-lg);
    -webkit-line-clamp: 3;
  }

  .post-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card__image-wrapper {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    position: relative;
  }

  .post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .post-card:hover .post-card__image {
    transform: scale(1.06);
  }

  .post-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-accent));
    opacity: 0.5;
  }

  .post-card__featured-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background-color: var(--color-accent);
    color: white;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    font-weight: 500;
  }

  .post-card__content {
    padding: var(--space-6);
  }

  .post-card__categories {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-card__category {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-weight: 500;
  }

  .post-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
    font-weight: 500;
  }

  .post-card__excerpt {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 300;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .post-card__reading::before,
  .post-card__author::before {
    content: '·';
    margin-right: var(--space-3);
  }

  @media (max-width: 768px) {
    .post-card--featured {
      grid-template-columns: 1fr;
    }

    .post-card--featured .post-card__link {
      grid-template-columns: 1fr;
    }

    .post-card--featured .post-card__title {
      font-size: var(--text-2xl);
    }
  }
</style>
