---
export interface Props {
  title: string;
  excerpt: string;
  publishDate: Date;
  slug: string;
  featuredImage?: string;
  categories?: string[];
  author?: string;
  readingTime?: number;
  featured?: boolean;
}

const { title, excerpt, publishDate, slug, featuredImage, categories, author, readingTime, featured } = Astro.props;
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const cardClass = featured ? 'post-card post-card--featured' : 'post-card';
---

<article class={cardClass}>
  <a href={`/posts/${slug}`} class="post-card__link">
    <div class="post-card__image-wrapper">
      {featuredImage ? (
        <img src={featuredImage} alt={title} class="post-card__image" loading="lazy" />
      ) : (
        <div class="post-card__image-placeholder"></div>
      )}
    </div>
    <div class="post-card__content">
      {categories && categories.length > 0 && (
        <div class="post-card__categories">
          {categories.map((cat) => (
            <span class="post-card__category">{cat}</span>
          ))}
        </div>
      )}
      <h3 class="post-card__title">{title}</h3>
      <p class="post-card__excerpt">{excerpt}</p>
      <div class="post-card__meta">
        <svg class="post-card__meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span class="post-card__meta-sep">·</span>
            <svg class="post-card__meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>{readingTime} min read</span>
          </>
        )}
        {author && (
          <>
            <span class="post-card__meta-sep">·</span>
            <svg class="post-card__meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>{author}</span>
          </>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .post-card {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow var(--transition);
    border: 1px solid var(--color-border);
  }

  .post-card:hover {
    box-shadow: var(--shadow-lg);
  }

  .post-card--featured {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .post-card--featured .post-card__link {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .post-card--featured .post-card__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-8);
  }

  .post-card--featured .post-card__title {
    font-size: var(--text-3xl);
  }

  .post-card--featured .post-card__excerpt {
    font-size: var(--text-lg);
    -webkit-line-clamp: 3;
  }

  .post-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .post-card__image-wrapper {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    position: relative;
  }

  .post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .post-card:hover .post-card__image {
    transform: scale(1.04);
  }

  .post-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-lighter));
    opacity: 0.3;
  }

  .post-card__content {
    padding: var(--space-5);
  }

  .post-card__categories {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .post-card__category {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-weight: 600;
    background-color: var(--color-accent-light);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .post-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
    font-weight: 500;
    transition: color var(--transition);
  }

  .post-card:hover .post-card__title {
    color: var(--color-accent);
  }

  .post-card__excerpt {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 300;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .post-card__meta-icon {
    flex-shrink: 0;
  }

  .post-card__meta-sep {
    margin: 0 var(--space-1);
  }

  @media (max-width: 768px) {
    .post-card--featured {
      grid-template-columns: 1fr;
    }

    .post-card--featured .post-card__link {
      grid-template-columns: 1fr;
    }

    .post-card--featured .post-card__title {
      font-size: var(--text-2xl);
    }

    .post-card--featured .post-card__content {
      padding: var(--space-5);
    }
  }
</style>
