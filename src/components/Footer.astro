---
import { getConfig } from '../lib/site-config';
const config = getConfig();
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/" class="footer__logo">Aethel_AI</a>
        <p class="footer__tagline">
          {config.site.tagline}
        </p>
        <div class="footer__social">
          <a href={config.social.twitter} class="footer__social-link" aria-label="Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={config.social.github} class="footer__social-link" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href={config.social.linkedin} class="footer__social-link" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
      <div class="footer__links">
        <h4 class="footer__heading">Navigate</h4>
        <ul class="footer__list">
          <li><a href="/">Home</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="footer__links">
        <h4 class="footer__heading">Categories</h4>
        <ul class="footer__list">
          <li><a href="/category/ai-tools">AI Tools</a></li>
          <li><a href="/category/productivity">Productivity</a></li>
          <li><a href="/category/automation">Automation</a></li>
          <li><a href="/category/trending">Trending</a></li>
        </ul>
      </div>
      <div class="footer__newsletter">
        <h4 class="footer__heading">Stay in touch</h4>
        <p class="footer__text">Get new posts delivered to your inbox.</p>
        <form class="footer__form" method="post" action="/api/newsletter">
          <input type="email" placeholder="Your email address" class="footer__input" required />
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>
      </div>
    </div>
    <div class="footer__bottom">
      <p>&copy; {year} {config.site.title}. {config.site.copyright}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0F1E36;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-20);
  }

  [data-theme="dark"] .footer {
    background: #0B1120;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap: var(--space-12);
    margin-bottom: var(--space-12);
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    font-style: italic;
    letter-spacing: -0.5px;
    color: #ffffff !important;
    text-decoration: none;
    transition: color var(--transition-slow);
  }

  .footer__tagline {
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.75);
    font-size: var(--text-base);
    margin-top: var(--space-3);
    font-weight: 300;
    max-width: 280px;
  }

  .footer__social {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    transition: all var(--transition);
  }

  .footer__social-link:hover {
    background-color: var(--color-accent);
    color: white;
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: var(--space-5);
    font-weight: 600;
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__list a {
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--text-base);
    transition: color var(--transition);
  }

  .footer__list a:hover {
    color: var(--color-accent);
  }

  .footer__text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: var(--space-4);
  }

  .footer__form {
    display: flex;
    gap: var(--space-2);
  }

  .footer__input {
    flex: 1;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.5;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--color-bg);
    outline: none;
    transition: border-color var(--transition);
    min-width: 0;
  }

  .footer__input:focus {
    border-color: var(--color-accent);
  }

  .footer__input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .footer__bottom {
    padding-top: var(--space-8);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .footer__bottom p {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  @media (max-width: 968px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer__form {
      flex-direction: column;
    }
  }
</style>
