---
import PostCard from './PostCard.astro';

export interface Props {
  posts: Array<{
    title: string;
    slug: string;
    excerpt: string;
    publishDate: Date;
    featuredImage?: string;
    categories?: string[];
    author?: string;
    readingTime?: number;
  }>;
}

const { posts } = Astro.props;
const id = 'rp-' + Math.random().toString(36).slice(2, 7);
---

{posts.length > 0 && (
  <section class="related-posts">
    <h2 class="related-posts__title">Related Posts</h2>
    <div class="related-posts__wrap">
      <button class="related-posts__arrow related-posts__arrow--left" id={id + '-l'} aria-label="Scroll left">&#10094;</button>
      <div class="related-posts__grid" id={id + '-g'}>
        {posts.map((post) => (
          <PostCard
            title={post.title}
            excerpt={post.excerpt}
            publishDate={post.publishDate}
            slug={post.slug}
            featuredImage={post.featuredImage}
            categories={post.categories}
            author={post.author}
            readingTime={post.readingTime}
            featured={false}
          />
        ))}
      </div>
      <button class="related-posts__arrow related-posts__arrow--right" id={id + '-r'} aria-label="Scroll right">&#10095;</button>
    </div>
  </section>
)}

<script>
  var grid = document.getElementById('{id}-g');
  var leftBtn = document.getElementById('{id}-l');
  var rightBtn = document.getElementById('{id}-r');
  if (grid && leftBtn && rightBtn) {
    function updateArrows() {
      leftBtn.style.display = grid.scrollLeft <= 2 ? 'none' : '';
      rightBtn.style.display = grid.scrollLeft + grid.clientWidth >= grid.scrollWidth - 2 ? 'none' : '';
    }
    grid.addEventListener('scroll', updateArrows);
    leftBtn.addEventListener('click', function() { grid.scrollBy({ left: -300, behavior: 'smooth' }); });
    rightBtn.addEventListener('click', function() { grid.scrollBy({ left: 300, behavior: 'smooth' }); });
    updateArrows();
  }
</script>

<style>
  .related-posts {
    margin-top: var(--space-12);
    padding-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    position: relative;
  }

  .related-posts__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
    color: var(--color-text);
  }

  .related-posts__wrap {
    position: relative;
  }

  .related-posts__grid {
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding: 0 var(--space-4);
    padding-bottom: var(--space-2);
    -webkit-overflow-scrolling: touch;
    -ms-overflow-style: none;
    scrollbar-width: none;
    align-items: stretch;
  }

  .related-posts__grid::-webkit-scrollbar {
    display: none;
  }

  .related-posts__grid > :global(.post-card) {
    flex: 0 0 280px;
    height: auto;
    scroll-snap-align: start;
  }

  .related-posts__arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    transition: opacity 0.2s ease;
    padding: 0;
    line-height: 1;
  }

  .related-posts__arrow:hover {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .related-posts__arrow--left {
    left: -18px;
  }

  .related-posts__arrow--right {
    right: -18px;
  }

  @media (max-width: 768px) {
    .related-posts__arrow {
      display: none !important;
    }
  }

  @media (max-width: 640px) {
    .related-posts__grid > :global(.post-card) {
      flex: 0 0 260px;
    }
  }
</style>
