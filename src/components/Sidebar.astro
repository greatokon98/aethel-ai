---
export interface Props {
  categories?: string[];
  recentPosts?: Array<{
    title: string;
    slug: string;
    publishDate: Date;
  }>;
  trendingPosts?: Array<{
    title: string;
    slug: string;
    publishDate: Date;
    readingTime?: number;
  }>;
  trending?: Array<{
    title: string;
    link: string;
    source: string;
    pubDate: string;
    description: string;
  }>;
  popularPosts?: Array<{
    title: string;
    slug: string;
    publishDate: Date;
  }>;
}

const { categories = [], recentPosts = [], trendingPosts = [], trending = [], popularPosts = [] } = Astro.props;

const displayPopular = (() => {
  if (popularPosts.length > 0) {
    const sorted = [...popularPosts].sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());
    const result = sorted.slice(0, 5);
    if (result.length < 5) {
      const fillCount = 5 - result.length;
      const pool = recentPosts.filter(p => !popularPosts.find(pp => pp.slug === p.slug));
      const shuffled = [...pool].sort(() => Math.random() - 0.5);
      result.push(...shuffled.slice(0, fillCount));
    }
    return result;
  }
  return recentPosts.slice(0, 5);
})();
---

<aside class="sidebar">
  <div class="sidebar__widget sidebar__search">
    <form class="sidebar__search-form" id="sidebar-search-form">
      <svg class="sidebar__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input type="text" id="sidebar-search-input" placeholder="Search articles..." class="sidebar__search-input" />
    </form>
    <script>
      document.getElementById('sidebar-search-form').addEventListener('submit', function(e) {
        e.preventDefault();
        var q = document.getElementById('sidebar-search-input').value.trim();
        if (!q) return;
        // Store query for admin analytics
        try {
          var queries = JSON.parse(localStorage.getItem('aa_search_queries') || '[]');
          queries.push({ query: q, timestamp: new Date().toISOString() });
          localStorage.setItem('aa_search_queries', JSON.stringify(queries));
        } catch(e) {}
        // Redirect to search results page with query
        window.location.href = '/?s=' + encodeURIComponent(q);
      });
    </script>
  </div>

  <div class="sidebar__widget">
    <h3 class="sidebar__widget-title">Trending Now</h3>
    <div class="sidebar__trending">
      {trendingPosts.length > 0 ? (
        trendingPosts.slice(0, 4).map((post, i) => (
          <a href={`/posts/${post.slug}`} class="sidebar__trending-item">
            <span class="sidebar__trending-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="sidebar__trending-content">
              <span class="sidebar__trending-title">{post.title}</span>
              <time class="sidebar__trending-date" datetime={post.publishDate.toISOString()}>
                {post.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </time>
            </div>
          </a>
        ))
      ) : recentPosts.length > 0 ? (
        recentPosts.slice(0, 4).map((post, i) => (
          <a href={`/posts/${post.slug}`} class="sidebar__trending-item">
            <span class="sidebar__trending-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="sidebar__trending-content">
              <span class="sidebar__trending-title">{post.title}</span>
              <time class="sidebar__trending-date" datetime={post.publishDate.toISOString()}>
                {post.publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
              </time>
            </div>
          </a>
        ))
      ) : (
        <p class="sidebar__text">No trending stories right now</p>
      )}
    </div>
  </div>

  <div class="sidebar__widget sidebar__categories">
    <h3 class="sidebar__widget-title">Categories</h3>
    <ul class="sidebar__list">
      {categories.length > 0 ? (
        categories.map((cat) => (
          <li>
            <a href={`/category/${cat.toLowerCase().replace(/\s+/g, '-')}`} class="sidebar__link">
              <span>{cat}</span>
              <svg class="sidebar__link-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          </li>
        ))
      ) : (
        <li><span class="sidebar__text">No categories yet</span></li>
      )}
    </ul>
  </div>

  <div class="sidebar__widget">
    <h3 class="sidebar__widget-title">Popular Posts</h3>
    <ul class="sidebar__posts">
      {displayPopular.length > 0 ? (
        displayPopular.map((post) => (
          <li class="sidebar__post-item">
            <div class="sidebar__post-body">
              <a href={`/posts/${post.slug}`} class="sidebar__post-link">
                {post.title}
              </a>
            </div>
            <time datetime={post.publishDate.toISOString()} class="sidebar__post-date">
              {post.publishDate.toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              })}
            </time>
          </li>
        ))
      ) : (
        <li><span class="sidebar__text">No posts yet</span></li>
      )}
    </ul>
  </div>

  <div class="sidebar__widget sidebar__newsletter">
    <h3 class="sidebar__widget-title">Newsletter</h3>
    <p class="sidebar__text">Get the latest AI insights delivered to your inbox.</p>
    <form class="sidebar__form" method="post" action="/api/newsletter">
      <input type="email" placeholder="Your email address" class="sidebar__input" required />
      <button type="submit" class="btn btn-primary sidebar__btn">Subscribe</button>
    </form>
  </div>
</aside>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar__widget {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .sidebar__widget-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-5);
    position: relative;
    padding-bottom: var(--space-3);
  }

  .sidebar__widget-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 28px;
    height: 2px;
    background-color: var(--color-accent);
    border-radius: 1px;
  }

  .sidebar__search-form {
    position: relative;
  }

  .sidebar__search-icon {
    position: absolute;
    left: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .sidebar__search-input {
    width: 100%;
    padding: var(--space-3) var(--space-3) var(--space-3) var(--space-10);
    font-family: var(--font-body);
    font-size: var(--text-base);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition);
  }

  .sidebar__search-input:focus {
    border-color: #2563EB;
  }

  [data-theme="dark"] .sidebar__search-input:focus {
    border-color: var(--color-accent-hover);
  }

  .sidebar__search-input::placeholder {
    color: var(--color-text-muted);
  }

  .sidebar__trending {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .sidebar__trending-item {
    display: flex;
    gap: var(--space-4);
    text-decoration: none;
    align-items: flex-start;
    position: relative;
  }

  .sidebar__trending-number {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
    min-width: 28px;
    opacity: 0.6;
  }

  .sidebar__trending-content {
    flex: 1;
    min-width: 0;
  }

  .sidebar__trending-title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    color: var(--color-text);
    display: block;
    margin-bottom: var(--space-1);
    line-height: var(--leading-snug);
    transition: color var(--transition);
    position: relative;
  }

  .sidebar__trending-title::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: #2563EB;
    transition: width 300ms ease;
  }

  [data-theme="dark"] .sidebar__trending-title::after {
    background: var(--color-accent-hover);
  }

  .sidebar__trending-item:hover .sidebar__trending-title::after {
    width: 100%;
  }

  .sidebar__trending-item:hover .sidebar__trending-title {
    color: #2563EB;
  }

  [data-theme="dark"] .sidebar__trending-item:hover .sidebar__trending-title {
    color: var(--color-accent-hover);
  }

  .sidebar__trending-date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .sidebar__list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .sidebar__list li {
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar__list li:last-child {
    border-bottom: none;
  }

  .sidebar__link {
    font-family: var(--font-body);
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) 0;
    transition: color var(--transition);
    position: relative;
  }

  .sidebar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #2563EB;
    transition: width 300ms ease;
  }

  [data-theme="dark"] .sidebar__link::after {
    background: var(--color-accent-hover);
  }

  .sidebar__link:hover::after {
    width: 100%;
  }

  .sidebar__link:hover {
    color: #2563EB;
  }

  [data-theme="dark"] .sidebar__link:hover {
    color: var(--color-accent-hover);
  }

  .sidebar__link-arrow {
    opacity: 0;
    transition: opacity var(--transition), transform var(--transition);
  }

  .sidebar__link:hover .sidebar__link-arrow {
    opacity: 1;
    transform: translateX(2px);
  }

  .sidebar__posts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .sidebar__post-item {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar__post-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sidebar__post-body {
    flex: 1;
  }

  .sidebar__post-link {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    color: var(--color-text);
    display: block;
    margin-bottom: var(--space-1);
    line-height: var(--leading-snug);
    font-weight: 400;
    transition: color var(--transition);
    position: relative;
  }

  .sidebar__post-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: #2563EB;
    transition: width 300ms ease;
  }

  [data-theme="dark"] .sidebar__post-link::after {
    background: var(--color-accent-hover);
  }

  .sidebar__post-link:hover::after {
    width: 100%;
  }

  .sidebar__post-link:hover {
    color: #2563EB;
  }

  [data-theme="dark"] .sidebar__post-link:hover {
    color: var(--color-accent-hover);
  }

  .sidebar__post-date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: auto;
  }

  .sidebar__text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .sidebar__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar__input {
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.5;
    text-align: left;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--transition);
  }

  .sidebar__input:focus {
    border-color: #2563EB;
  }

  [data-theme="dark"] .sidebar__input:focus {
    border-color: var(--color-accent-hover);
  }

  .sidebar__btn {
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .sidebar__btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: rgba(255, 255, 255, 0.5);
    transition: width var(--transition);
  }

  .sidebar__btn:hover::after {
    width: 100%;
  }

  @media (max-width: 1024px) {
    .sidebar__widget {
      padding: var(--space-4);
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }

    .sidebar__newsletter {
      grid-column: 1 / -1;
    }

    .sidebar__trending-item {
      gap: var(--space-3);
    }

    .sidebar__search,
    .sidebar__categories {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>
